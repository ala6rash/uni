@* 
    This page receives a ResetPasswordViewModel from the controller.
    User enters: Reset Token (hidden), New Password, Confirm Password
    The form sends the data back to the controller when submitted.
*@
@model Uni_Connect.ViewModels.ResetPasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>Reset Password — UniConnect</title>
    <link href="~/css/login.css" rel="stylesheet" />
</head>
<body class="auth-bg">

<!-- ===== NAVIGATION BAR ===== -->
<nav class="auth-navbar">
    <a asp-controller="Home" asp-action="Index" class="nav-logo">
        <div class="nav-logo-icon">🎓</div>
        <span>UniConnect</span>
    </a>
</nav>

<!-- ===== MAIN CONTENT ===== -->
<div class="auth-body">
  <div style="width:100%;max-width:460px">
    
    <!-- ===== PAGE HEADER ===== -->
    <div style="text-align:center;margin-bottom:24px">
      <div class="auth-logo-icon">🔐</div>
      <h1 class="auth-title">Reset your password</h1>
      <p class="auth-subtitle">Enter your new password below</p>
    </div>

    <!-- ===== RESET FORM ===== -->
    <form asp-action="ResetPassword" method="post">
      @Html.AntiForgeryToken()
      <div class="auth-card">
        
        <!-- ===== ERROR MESSAGES ===== -->
        <!-- This shows general errors like "Invalid reset code" or "Token expired" -->
        <div asp-validation-summary="ModelOnly" class="validation-error-box"></div>

        <!-- ===== HIDDEN RESET TOKEN ===== -->
        <!-- This field is hidden - user doesn't see it -->
        <!-- It contains the reset token from the URL query string -->
        <!-- The controller uses it to verify the user owns this email -->
        <input type="hidden" asp-for="ResetToken" />

        <!-- ===== NEW PASSWORD FIELD ===== -->
        <div class="form-group">
          <label class="form-label" asp-for="NewPassword">New Password</label>
          <input 
            class="form-input" 
            asp-for="NewPassword" 
            type="password" 
            placeholder="Enter new password" />
          <div class="form-hint">
            Must include:
            <br/>• At least 8 characters
            <br/>• One UPPERCASE letter (A-Z)
            <br/>• One lowercase letter (a-z)
            <br/>• One number (0-9)
            <br/>• One special character (!@@#$%^&*)
            <br/>Example: MyPassword@123
          </div>
          <span asp-validation-for="NewPassword" class="field-validation-error"></span>
        </div>

        <!-- ===== CONFIRM PASSWORD FIELD ===== -->
        <div class="form-group" style="margin-bottom:22px">
          <label class="form-label" asp-for="ConfirmPassword">Confirm Password</label>
          <input 
            class="form-input" 
            asp-for="ConfirmPassword" 
            type="password" 
            placeholder="Re-enter your password" />
          <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
        </div>

        <!-- ===== SUBMIT BUTTON ===== -->
        <button type="submit" class="btn btn-primary btn-full btn-lg">
          Reset Password →
        </button>
        
        <!-- ===== BACK TO LOGIN LINK ===== -->
        <div style="text-align:center;margin-top:16px">
          <a asp-controller="Login" asp-action="Login" 
             style="color:var(--indigo);font-weight:600;font-size:14px">
            Back to Sign In
          </a>
        </div>
      </div>
    </form>

    <!-- ===== SECURITY NOTICE ===== -->
    <div class="auth-notice">
      <span style="font-size:18px;flex-shrink:0">🔐</span>
      <p>Your password is securely encrypted and never shared with anyone.</p>
    </div>
  </div>
</div>

<!-- ===== CLIENT-SIDE VALIDATION SCRIPTS ===== -->
<!-- These add instant validation in the browser before form submission -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>
