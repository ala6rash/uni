@model Uni_Connect.ViewModels.ForgotPasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Forgot Password — UniConnect</title>
    <link href="~/css/login.css" rel="stylesheet" />
</head>
<body class="auth-bg">

<nav class="auth-navbar">
    <a asp-controller="Home" asp-action="Index" class="nav-logo">
        <div class="nav-logo-icon">🎓</div>
        <span>UniConnect</span>
    </a>
    <div style="display:flex;align-items:center;gap:12px">
        <span style="font-size:14px;color:var(--text-2)">Remember your password?</span>
        <a asp-controller="Login" asp-action="Login"><button class="btn btn-ghost btn-sm">Sign In</button></a>
    </div>
</nav>

<div class="auth-body">
  <div style="width:100%;max-width:460px">

    @if (ViewBag.EmailSent == true)
    {
        @* ===== STEP 2: Email sent confirmation ===== *@
        <div class="auth-card" style="text-align:center;padding:40px 32px">
            <div style="width:80px;height:80px;background:var(--emerald-light);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:38px;margin:0 auto 20px">📧</div>
            <h1 class="auth-title" style="margin-bottom:10px">Check your inbox!</h1>
            <p style="font-size:14px;color:var(--text-2);line-height:1.7;margin-bottom:8px">We sent a password reset link to:</p>
            <div style="font-size:15px;font-weight:800;color:var(--indigo);background:var(--indigo-light);border-radius:10px;padding:10px 18px;margin-bottom:22px;display:inline-block">@ViewBag.SentToEmail</div>
            <p style="font-size:13px;color:var(--text-2);line-height:1.7;margin-bottom:28px">Click the link in the email to reset your password. The link expires in <strong>15 minutes</strong>.</p>
            
            <div style="margin-top:16px;font-size:13px;color:var(--text-2)">
                Didn't receive it? <a asp-controller="Login" asp-action="ForgotPassword" style="color:var(--indigo);font-weight:700">Try again</a>
            </div>
            <div style="margin-top:18px">
                <a asp-controller="Login" asp-action="Login" style="font-size:14px;color:var(--text-2);font-weight:600">← Back to Sign In</a>
            </div>
        </div>
    }
    else
    {
        @* ===== STEP 1: Enter email ===== *@
        <div style="text-align:center;margin-bottom:24px">
            <div class="auth-logo-icon">🔑</div>
            <h1 class="auth-title">Forgot password?</h1>
            <p class="auth-subtitle">No worries! Enter your university email and we'll send you a reset link.</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="auth-card">
                <div asp-validation-summary="ModelOnly" class="validation-error-box"></div>

                <div class="form-group" style="margin-bottom:22px">
                    <label class="form-label" asp-for="Email">University Email</label>
                    <input class="form-input" asp-for="Email" type="email" placeholder="StudentID@@philadelphia.edu.jo" />
                    <div class="form-hint">We'll send a reset link to this email</div>
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-full btn-lg">Send Reset Link →</button>
            </div>
        </form>

        <div style="text-align:center;margin-top:20px">
            <a asp-controller="Login" asp-action="Login" style="font-size:14px;color:var(--indigo);font-weight:700">← Back to Sign In</a>
        </div>
    }

    <div class="auth-notice"><span style="font-size:18px;flex-shrink:0">🔒</span><p>Password reset is only available for registered @@philadelphia.edu.jo email addresses.</p></div>
  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>