@model Uni_Connect.ViewModels.SinglePostViewModel

@{
    Layout = null;
    string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if (span.TotalDays >= 1) return $"{(int)span.TotalDays}d ago";
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours}h ago";
        if (span.TotalMinutes >= 1) return $"{(int)span.TotalMinutes}m ago";
        return "Just now";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>@Model.Post.Title — UniConnect</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
:root{--indigo:#3D52A0;--indigo-dark:#2d3f7a;--indigo-light:#EEF2FF;--violet:#7091E6;--violet-light:#EDE9FE;--amber:#F59E0B;--amber-light:#FEF3C7;--emerald:#10B981;--emerald-light:#D1FAE5;--rose:#F43F5E;--bg:#F8F9FF;--surface:#fff;--border:#E2E8F0;--text:#0F172A;--text-2:#64748B;--radius:12px;--sidebar:260px}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);font-size:15px}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}
.navbar{position:sticky;top:0;z-index:200;height:68px;background:rgba(255,255,255,.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 5%}
.nav-logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:22px;color:var(--indigo)}
.nav-logo-icon{width:38px;height:38px;background:var(--indigo);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:19px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;padding:10px 22px;border-radius:9px;font-weight:600;font-size:14px;border:none;cursor:pointer;transition:all .2s;min-height:44px;font-family:inherit}
.btn-primary{background:var(--indigo);color:#fff}.btn-primary:hover{background:var(--indigo-dark)}
.btn-ghost{background:transparent;color:var(--text-2);border:1.5px solid var(--border)}.btn-ghost:hover{background:var(--bg)}
.btn-sm{padding:7px 14px;font-size:13px;min-height:36px}
.chip{display:inline-flex;align-items:center;padding:3px 10px;border-radius:99px;font-size:12px;font-weight:600}
.chip-indigo{background:var(--indigo-light);color:var(--indigo)}
.chip-violet{background:var(--violet-light);color:#5B21B6}
.chip-amber{background:var(--amber-light);color:#92400E}
.chip-emerald{background:var(--emerald-light);color:#065F46}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:24px}
.form-input{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:9px;font-size:14px;font-family:inherit;outline:none;transition:border-color .2s}
.form-input:focus{border-color:var(--indigo)}
.form-textarea{min-height:130px;resize:vertical;line-height:1.6}
.av{border-radius:50%;overflow:hidden;flex-shrink:0}
.av img{width:100%;height:100%;object-fit:cover}
.av-sm{width:36px;height:36px}
.av-md{width:44px;height:44px}
.app-wrap{display:flex;min-height:calc(100vh - 68px)}
.sidebar{width:var(--sidebar);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:68px;height:calc(100vh - 68px);overflow-y:auto}
.sidebar-user{display:flex;align-items:center;gap:12px;padding:16px 20px 20px;border-bottom:1px solid var(--border);cursor:pointer}
.sidebar-user-name{font-weight:700;font-size:15px}
.sidebar-user-pts{font-size:12px;color:var(--amber);font-weight:600;margin-top:2px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;font-size:14px;font-weight:500;color:var(--text-2);cursor:pointer;transition:all .2s;border-right:3px solid transparent}
.nav-item:hover,.nav-item.active{background:var(--indigo-light);color:var(--indigo)}
.nav-item.active{font-weight:700;border-right-color:var(--indigo)}
.ni{font-size:17px;width:22px;text-align:center}
.pts-card{margin:12px 16px;background:linear-gradient(135deg,#F59E0B,#F97316);border-radius:12px;padding:14px;color:#fff}
.main{flex:1;padding:28px 32px;max-width:820px;min-width:0}
@@keyframes slideUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>
<nav class="navbar">
  <a href="/Dashboard/Dashboard" class="nav-logo"><div class="nav-logo-icon">🎓</div>UniConnect</a>
  <div style="flex:1;max-width:480px;margin:0 24px"><input class="form-input" placeholder="🔍  Search questions..." style="min-height:40px"></div>
  <div style="display:flex;align-items:center;gap:10px">
    <a href="/Post/Create"><button class="btn btn-primary btn-sm">+ Ask Question</button></a>
    <a href="/Dashboard/Profile"><div class="av av-sm"><img src="@(Model.CurrentUser?.ProfileImageUrl ?? "https://i.pravatar.cc/36?u="+Model.CurrentUser?.UserID)" alt="@Model.CurrentUser?.Name"></div></a>
  </div>
</nav>

<div class="app-wrap">
  <aside class="sidebar">
    <a href="/Dashboard/Profile" class="sidebar-user">
      <div class="av av-md"><img src="@(Model.CurrentUser?.ProfileImageUrl ?? "https://i.pravatar.cc/44?u="+Model.CurrentUser?.UserID)" alt="@Model.CurrentUser?.Name"></div>
      <div><div class="sidebar-user-name">@Model.CurrentUser?.Name</div><div class="sidebar-user-pts">🪙 @Model.CurrentUser?.Points pts</div></div>
    </a>
    <div style="padding:12px 0;flex:1">
      <a href="/Dashboard/Dashboard"><div class="nav-item"><span class="ni">🏠</span>Home Feed</div></a>
      <div class="nav-item active"><span class="ni">💬</span>Question</div>
      <a href="/Post/Create"><div class="nav-item"><span class="ni">✏️</span>Ask a Question</div></a>
      <a href="/Sessions"><div class="nav-item"><span class="ni">🎓</span>Sessions</div></a>
      <a href="/Dashboard/Leaderboard"><div class="nav-item"><span class="ni">🏆</span>Leaderboard</div></a>
      <a href="/Dashboard/Profile"><div class="nav-item"><span class="ni">👤</span>My Profile</div></a>
    </div>
    <div class="pts-card">
      <div style="font-size:26px;font-weight:800;line-height:1">@Model.CurrentUser?.Points</div>
      <div style="font-size:12px;opacity:.85;margin-top:2px">🪙 Your Points</div>
    </div>
  </aside>

  <main class="main">
    <!-- Breadcrumb -->
    <div style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-2);margin-bottom:20px;flex-wrap:wrap">
      <a href="/Dashboard/Dashboard" style="color:var(--indigo);font-weight:600">Home</a>
      <span>›</span><span>@(Model.Post.Category?.Faculty ?? "General")</span><span>›</span><span>@(Model.Post.Category?.Name ?? "")</span><span>›</span>
      <span style="color:var(--text);font-weight:600">@Model.Post.Title</span>
    </div>

    <!-- Question Card -->
    <div class="card" style="margin-bottom:24px">
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px">
        <span class="chip chip-indigo">@(Model.Post.Category?.Faculty ?? "General")</span>
        <span class="chip chip-violet">@(Model.Post.Category?.Name ?? "Question")</span>
        <span style="font-size:12px;color:var(--text-2);margin-left:4px">· @GetTimeAgo(Model.Post.CreatedAt) · @Model.Post.ViewsCount views</span>
      </div>
      <h1 style="font-size:26px;font-weight:800;margin-bottom:14px;line-height:1.3">@Model.Post.Title</h1>
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px">
        <div class="av av-sm"><img src="@(Model.Post.User?.ProfileImageUrl ?? "https://i.pravatar.cc/36?u="+Model.Post.UserID)" alt="@Model.Post.User?.Name"></div>
        <span style="font-weight:600;font-size:14px">@Model.Post.User?.Name</span>
        <span style="font-size:13px;color:var(--text-2)">@Model.Post.User?.Role</span>
      </div>
      <p style="font-size:15px;line-height:1.7;margin-bottom:18px;white-space:pre-wrap">@Model.Post.Content</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-ghost btn-sm">👍 Upvote (@Model.Post.Upvotes)</button>
        <button class="btn btn-ghost btn-sm">🔖 Save</button>
        <button class="btn btn-ghost btn-sm">⚑ Report</button>
        <a href="/Sessions" style="margin-left:auto"><button class="btn btn-primary btn-sm">💬 Request Private Session</button></a>
      </div>
    </div>

    <!-- Answers Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
      <h2 style="font-size:20px;font-weight:800">@(Model.Answers?.Count ?? 0) Answers</h2>
      <select class="form-input" style="width:auto;font-size:13px;min-height:36px;padding:6px 32px 6px 12px">
        <option>Best Rated</option><option>Most Recent</option>
      </select>
    </div>

    <!-- Answers Loop -->
    @if (Model.Answers != null && Model.Answers.Any())
    {
      foreach (var answer in Model.Answers)
      {
        <div class="card" style="margin-bottom:16px;@(answer.IsAccepted ? "border:2px solid var(--emerald);background:rgba(209,250,229,.12);" : "")position:relative">
          @if(answer.IsAccepted){
            <div style="position:absolute;top:-12px;left:20px;background:var(--emerald);color:#fff;padding:3px 14px;border-radius:99px;font-size:12px;font-weight:700;box-shadow:0 3px 10px rgba(16,185,129,.3)">✓ Best Answer</div>
          }
          <div style="display:flex;align-items:flex-start;gap:12px;margin-bottom:14px;margin-top:@(answer.IsAccepted ? "6px" : "0")">
            <div class="av av-md"><img src="@(answer.User?.ProfileImageUrl ?? "https://i.pravatar.cc/44?u="+answer.User?.UserID)" alt="@answer.User?.Name"></div>
            <div style="flex:1">
              <div style="font-weight:700">@answer.User?.Name @if(answer.User?.Points > 500){<span style="color:var(--emerald);font-size:13px">✓ Verified Tutor</span>}</div>
              <div style="font-size:13px;color:var(--text-2)">@answer.User?.Role · Answered @GetTimeAgo(answer.CreatedAt)</div>
            </div>
            <div id="upvote-@answer.AnswerID" onclick="performUpvote(@answer.AnswerID,this)" style="@(answer.IsAccepted ? "background:var(--amber-light);border:1px solid #FDE68A;" : "background:var(--bg);border:1px solid var(--border);")padding:8px 14px;border-radius:8px;text-align:center;cursor:pointer;min-width:54px;transition:all .2s">
              <div style="font-size:16px;font-weight:900" class="arrow">↑</div>
              <div style="font-size:14px;font-weight:700;@(answer.IsAccepted ? "color:#92400E;" : "")" class="score">@answer.Upvotes</div>
            </div>
          </div>
          <p style="margin-bottom:12px;line-height:1.7;white-space:pre-wrap;font-size:14px">@answer.Content</p>
          @if(answer.IsAccepted){
            <pre style="background:var(--bg);padding:16px;border-radius:10px;font-size:13px;overflow-x:auto;border:1px solid var(--border);line-height:1.7;margin-bottom:12px;white-space:pre-wrap">Marked as Best Answer ✓</pre>
          }
          <div style="display:flex;gap:10px;margin-top:14px">
            <button class="btn btn-ghost btn-sm">💬 Reply</button>
            <button class="btn btn-ghost btn-sm">⚑ Report</button>
          </div>
        </div>
      }
    }

    <!-- Write Answer -->
    <div class="card" style="border:2px solid var(--indigo-light);margin-top:24px">
      <h3 style="font-size:17px;font-weight:700;margin-bottom:14px">✏️ Write Your Answer</h3>
      <form asp-action="PostAnswer" asp-controller="Post" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="postId" value="@Model.Post.PostID"/>
        <div style="display:flex;gap:6px;margin-bottom:6px;padding:8px;background:var(--bg);border-radius:8px;border:1px solid var(--border)">
          <button type="button" class="btn btn-ghost btn-sm" style="min-height:30px;padding:4px 10px"><strong>B</strong></button>
          <button type="button" class="btn btn-ghost btn-sm" style="min-height:30px;padding:4px 10px"><em>I</em></button>
          <button type="button" class="btn btn-ghost btn-sm" style="min-height:30px;padding:4px 10px;font-family:monospace">{ }</button>
          <button type="button" class="btn btn-ghost btn-sm" style="min-height:30px;padding:4px 10px">🖼️</button>
        </div>
        <textarea asp-for="NewAnswerContent" required class="form-input form-textarea" style="width:100%;min-height:130px" placeholder="Write a detailed explanation... Be specific and helpful!"></textarea>
        <div style="display:flex;justify-content:space-between;align-items:center;margin-top:14px">
          <span style="font-size:13px;color:var(--text-2)">Quality answers earn <strong style="color:var(--amber)">+10 pts</strong> when upvoted</span>
          <button type="submit" class="btn btn-primary">Post Answer →</button>
        </div>
      </form>
    </div>
  </main>
</div>

<script>
async function performUpvote(answerId, element) {
  if (element.dataset.voted === "true") return;
  try {
    const response = await fetch('/Post/UpvoteAnswer', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(answerId)
    });
    if (response.ok) {
      const data = await response.json();
      if (data.success) {
        element.dataset.voted = "true";
        element.style.background = "var(--amber-light)";
        element.style.borderColor = "#FDE68A";
        element.querySelector('.score').textContent = data.newUpvotes;
        element.querySelector('.score').style.color = "#92400E";
        element.querySelector('.arrow').style.color = "#92400E";
        // Toast
        const t = document.createElement('div');
        t.textContent = '🎉 Upvoted! +10 pts given to author';
        t.style.cssText='position:fixed;bottom:32px;right:32px;z-index:999;background:#10B981;color:#fff;padding:14px 22px;border-radius:10px;font-weight:600;font-size:14px;box-shadow:0 4px 20px rgba(0,0,0,.15)';
        document.body.appendChild(t);setTimeout(()=>t.remove(),3000);
      }
    }
  } catch(e) { console.error(e); }
}
</script>
</body>
</html>
