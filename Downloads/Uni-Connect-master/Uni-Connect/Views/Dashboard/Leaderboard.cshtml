@{
    Layout = null;
    var currentUser = ViewBag.CurrentUser as Uni_Connect.Models.User;
    var allUsers = ViewBag.AllUsers as List<Uni_Connect.Models.User> ?? new List<Uni_Connect.Models.User>();

    string Medal(int rank) => rank == 1 ? "🥇" : rank == 2 ? "🥈" : rank == 3 ? "🥉" : rank.ToString();
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Leaderboard — UniConnect</title>
<link href="~/css/site.css" rel="stylesheet"/>
<link href="~/css/Home.css" rel="stylesheet"/>
</head>
<body>
<nav class="navbar">
  <a href="/Dashboard" class="nav-logo" style="text-decoration:none"><div class="nav-logo-icon">🎓</div><span>UniConnect</span></a>
  <div style="display:flex;align-items:center;gap:10px">
    <a href="/Post/Create"><button class="btn btn-primary btn-sm">+ Ask Question</button></a>
    <div class="av av-sm"><img src="@(currentUser?.ProfileImageUrl ?? "https://i.pravatar.cc/36?u=" + currentUser?.UserID)" alt="@currentUser?.Name"></div>
  </div>
</nav>
<div class="app-wrap">
  <aside class="sidebar">
    <a href="/Dashboard/Profile" class="sidebar-user">
      <div class="av av-md"><img src="@(currentUser?.ProfileImageUrl ?? "https://i.pravatar.cc/44?u=" + currentUser?.UserID)" alt="@currentUser?.Name"></div>
      <div>
        <div class="sidebar-user-name">@currentUser?.Name</div>
        <div class="sidebar-user-pts">🪙 @currentUser?.Points pts</div>
      </div>
    </a>
    <div style="padding:12px 0;flex:1">
      <a href="/Dashboard"><div class="nav-item"><span class="ni">🏠</span>Home Feed</div></a>
      <a href="/Post/Create"><div class="nav-item"><span class="ni">✏️</span>Ask a Question</div></a>
      <a href="/Sessions"><div class="nav-item"><span class="ni">💬</span>My Sessions</div></a>
      <div class="nav-item active"><span class="ni">🏆</span>Leaderboard</div>
      <a href="/Dashboard/Profile"><div class="nav-item"><span class="ni">👤</span>My Profile</div></a>
    </div>
    <div style="margin:12px 16px;background:linear-gradient(135deg,#F59E0B,#F97316);border-radius:12px;padding:14px;color:#fff">
      <div style="font-size:26px;font-weight:800;line-height:1">@currentUser?.Points</div>
      <div style="font-size:12px;opacity:.85;margin-top:2px">🪙 Your Points</div>
    </div>
  </aside>
  <main style="flex:1;padding:28px 32px;min-width:0">
    <div style="margin-bottom:20px">
      <h1 style="font-size:24px;font-weight:800">🏆 Leaderboard</h1>
      <p style="color:var(--text-2);font-size:14px;margin-top:4px">Top contributors — Philadelphia University</p>
    </div>

    @if (allUsers.Count >= 3)
    {
      <div style="display:flex;justify-content:center;align-items:flex-end;gap:16px;margin-bottom:32px;flex-wrap:wrap">
        <div style="text-align:center;flex:1;max-width:180px">
          <div style="background:#fff;border:2px solid #C0C0C0;border-radius:14px;padding:20px 16px;position:relative">
            <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:28px">🥈</div>
            <div class="av" style="width:72px;height:72px;margin:12px auto 10px;border:3px solid #C0C0C0"><img src="https://i.pravatar.cc/72?u=@allUsers[1].UserID" alt="@allUsers[1].Name"></div>
            <div style="font-weight:800;font-size:14px">@allUsers[1].Name</div>
            <div style="font-size:22px;font-weight:800;color:var(--amber);margin-top:8px">@allUsers[1].Points</div>
            <div style="font-size:11px;color:var(--text-2)">points</div>
          </div>
        </div>
        <div style="text-align:center;flex:1;max-width:200px">
          <div style="background:linear-gradient(135deg,#FEF3C7,#FDE68A);border:2px solid var(--amber);border-radius:14px;padding:24px 16px;position:relative;box-shadow:0 8px 28px rgba(245,158,11,.2)">
            <div style="position:absolute;top:-16px;left:50%;transform:translateX(-50%);font-size:32px">🥇</div>
            <div class="av" style="width:88px;height:88px;margin:12px auto 10px;border:3px solid var(--amber)"><img src="https://i.pravatar.cc/88?u=@allUsers[0].UserID" alt="@allUsers[0].Name"></div>
            <div style="font-weight:800;font-size:16px">@allUsers[0].Name</div>
            <div style="font-size:28px;font-weight:800;color:#D97706;margin-top:8px">@allUsers[0].Points</div>
            <div style="font-size:11px;color:var(--text-2)">points</div>
          </div>
        </div>
        <div style="text-align:center;flex:1;max-width:180px">
          <div style="background:#fff;border:2px solid #CD7F32;border-radius:14px;padding:20px 16px;position:relative">
            <div style="position:absolute;top:-14px;left:50%;transform:translateX(-50%);font-size:28px">🥉</div>
            <div class="av" style="width:72px;height:72px;margin:12px auto 10px;border:3px solid #CD7F32"><img src="https://i.pravatar.cc/72?u=@allUsers[2].UserID" alt="@allUsers[2].Name"></div>
            <div style="font-weight:800;font-size:14px">@allUsers[2].Name</div>
            <div style="font-size:22px;font-weight:800;color:var(--amber);margin-top:8px">@allUsers[2].Points</div>
            <div style="font-size:11px;color:var(--text-2)">points</div>
          </div>
        </div>
      </div>
    }

    <div class="card" style="padding:0;overflow:hidden;border-radius:12px">
      <div style="padding:12px 18px;font-weight:700;font-size:13px;border-bottom:2px solid var(--border);display:flex;gap:14px;color:var(--text-2)">
        <span style="width:36px">#</span>
        <span style="flex:1">Student</span>
        <span style="width:90px;text-align:center">Points</span>
        <span style="width:90px;text-align:center">Status</span>
      </div>
      @{ int rank = 0; }
      @foreach (var u in allUsers)
      {
        rank++;
        bool isMe = u.UserID == currentUser?.UserID;
        <div style="display:flex;align-items:center;gap:14px;padding:14px 18px;border-bottom:1px solid var(--border);@(isMe ? "background:linear-gradient(90deg,rgba(61,82,160,.06),transparent);border-left:3px solid var(--indigo);" : "")transition:background .2s">
          <div style="width:36px;text-align:center;font-weight:800;font-size:@(rank<=3?"18":"15")px;color:@(isMe?"var(--indigo)":"var(--text-2)")">@Medal(rank)</div>
          <div class="av av-sm" style="@(isMe?"border:2px solid var(--indigo);":"")"><img src="https://i.pravatar.cc/36?u=@u.UserID" alt="@u.Name"></div>
          <div style="flex:1;margin-left:4px">
            <div style="font-weight:@(isMe?"700":"600");font-size:14px;color:@(isMe?"var(--indigo)":"var(--text)")">
              @u.Name @if(isMe){<span style="font-size:11px;background:var(--indigo-light);padding:2px 8px;border-radius:99px;color:var(--indigo)">You</span>}
            </div>
            <div style="font-size:12px;color:var(--text-2)">@u.UniversityID</div>
          </div>
          <div style="width:90px;text-align:center;font-weight:700;color:var(--amber)">🪙 @u.Points</div>
          <div style="width:90px;text-align:center">
            @if(u.Points>=1000){<span class="chip" style="background:var(--amber-light);color:#92400E;font-size:11px">Tutor ✓</span>}
            else{<span class="chip" style="background:#F1F5F9;color:var(--text-2);font-size:11px">Student</span>}
          </div>
        </div>
      }
    </div>
  </main>
</div>
</body>
</html>