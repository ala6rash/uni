@{
    Layout = null;
    var user = ViewBag.CurrentUser as Uni_Connect.Models.User;
    var myPosts = ViewBag.MyPosts as List<Uni_Connect.Models.Post> ?? new List<Uni_Connect.Models.Post>();
    var myAnswers = ViewBag.MyAnswers as List<Uni_Connect.Models.Answer> ?? new List<Uni_Connect.Models.Answer>();

    string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if (span.TotalDays > 1) return $"{(int)span.TotalDays} days ago";
        if (span.TotalHours > 1) return $"{(int)span.TotalHours} hours ago";
        if (span.TotalMinutes > 1) return $"{(int)span.TotalMinutes} minutes ago";
        return "Just now";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>@user?.Name — UniConnect</title>
<link href="~/css/site.css" rel="stylesheet"/>
<link href="~/css/Home.css" rel="stylesheet"/>
<style>
  .tabs{display:flex;gap:4px;border-bottom:2px solid var(--border);margin-bottom:20px}
  .tab{padding:10px 16px;font-size:14px;font-weight:600;color:var(--text-2);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;border-radius:8px 8px 0 0;transition:all .2s}
  .tab:hover{color:var(--indigo);background:var(--indigo-light)}
  .tab.active{color:var(--indigo);border-bottom-color:var(--indigo)}
</style>
</head>
<body>
<nav class="navbar">
  <a href="/Dashboard" class="nav-logo" style="text-decoration:none"><div class="nav-logo-icon">🎓</div><span>UniConnect</span></a>
  <div style="display:flex;align-items:center;gap:10px">
    <a href="/Dashboard"><button class="btn btn-ghost btn-sm">← Back to Feed</button></a>
  </div>
</nav>

<div style="max-width:900px;margin:0 auto;padding:32px 24px">
  <!-- Cover + Avatar -->
  <div style="height:180px;border-radius:16px;overflow:hidden;margin-bottom:56px;position:relative">
    <img src="https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=900&q=80" alt="" style="width:100%;height:100%;object-fit:cover">
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 40%,rgba(61,82,160,.45))"></div>
    <div style="position:absolute;bottom:-44px;left:28px">
      <div class="av" style="width:92px;height:92px;border:4px solid #fff;box-shadow:0 4px 16px rgba(0,0,0,.15)">
        <img src="@(user?.ProfileImageUrl ?? "https://i.pravatar.cc/92?u=" + user?.UserID)" alt="@user?.Name">
      </div>
    </div>
  </div>

  <!-- Info row -->
  <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;flex-wrap:wrap;gap:12px">
    <div>
      <h1 style="font-size:26px;font-weight:800;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        @user?.Name
        @if (user?.Points >= 1000) { <span style="color:var(--emerald);font-size:16px">✓</span><span class="chip" style="background:var(--emerald-light);color:#065F46">Verified Tutor</span> }
      </h1>
      <p style="color:var(--text-2);font-size:14px;margin-top:4px">University ID: @user?.UniversityID · Role: @user?.Role</p>
    </div>
    <a href="/Dashboard"><button class="btn btn-ghost btn-sm">← Back</button></a>
  </div>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px">
    <div class="card" style="text-align:center;padding:16px 8px;border-radius:12px">
      <div style="font-size:26px;font-weight:800;color:var(--amber)">@user?.Points</div>
      <div style="font-size:11px;color:var(--text-2);margin-top:4px">Total Points</div>
    </div>
    <div class="card" style="text-align:center;padding:16px 8px;border-radius:12px">
      <div style="font-size:26px;font-weight:800">@myPosts.Count</div>
      <div style="font-size:11px;color:var(--text-2);margin-top:4px">Questions Asked</div>
    </div>
    <div class="card" style="text-align:center;padding:16px 8px;border-radius:12px">
      <div style="font-size:26px;font-weight:800">@myAnswers.Count</div>
      <div style="font-size:11px;color:var(--text-2);margin-top:4px">Recent Answers</div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <div class="tab active" onclick="switchTab(this,'tab-answers')">Recent Answers</div>
    <div class="tab" onclick="switchTab(this,'tab-questions')">Questions Asked</div>
  </div>

  <!-- Recent Answers Tab -->
  <div id="tab-answers" style="display:flex;flex-direction:column;gap:14px">
    @if (myAnswers.Any())
    {
      foreach (var ans in myAnswers)
      {
        <div class="card" style="border-radius:12px;padding:20px">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap">
            <span class="chip chip-indigo">@(ans.Post?.Category?.Name ?? "General")</span>
            <span style="font-size:12px;color:var(--text-2)">· @GetTimeAgo(ans.CreatedAt)</span>
            @if (ans.IsAccepted) { <span class="chip" style="background:var(--emerald-light);color:#065F46">✓ Best Answer</span> }
            <span class="chip" style="background:var(--amber-light);color:#92400E;margin-left:auto">+@(ans.IsAccepted ? 15 : 5) pts</span>
          </div>
          <p style="font-size:14px;color:var(--text-2);line-height:1.7;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">@ans.Content</p>
          <div style="margin-top:10px;font-size:13px;color:var(--text-2)">👍 @ans.Upvotes upvotes</div>
        </div>
      }
    }
    else
    {
      <div style="text-align:center;padding:40px;color:var(--text-2)">
        <div style="font-size:40px;margin-bottom:12px">💬</div>
        <p>No answers yet. Start helping your classmates!</p>
        <a href="/Dashboard" style="display:inline-block;margin-top:12px"><button class="btn btn-primary btn-sm">Browse Questions</button></a>
      </div>
    }
  </div>

  <!-- Questions Tab -->
  <div id="tab-questions" style="display:none;flex-direction:column;gap:14px">
    @if (myPosts.Any())
    {
      foreach (var post in myPosts)
      {
        <a href="/Post/SinglePost/@post.PostID" class="card" style="border-radius:12px;padding:20px;display:block;text-decoration:none;color:inherit;transition:box-shadow .2s" onmouseover="this.style.boxShadow='0 6px 24px rgba(61,82,160,.1)'" onmouseout="this.style.boxShadow='none'">
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px">
            <span class="chip chip-indigo">@(post.Category?.Faculty ?? "General")</span>
            <span class="chip chip-violet">@(post.Category?.Name ?? "Question")</span>
            <span style="font-size:12px;color:var(--text-2)">· @GetTimeAgo(post.CreatedAt)</span>
          </div>
          <div style="font-weight:700;font-size:15px;margin-bottom:6px">@post.Title</div>
          <div style="font-size:13px;color:var(--text-2);display:flex;gap:14px">
            <span>👍 @post.Upvotes</span>
            <span>💬 @(post.Answers?.Count ?? 0) answers</span>
            <span>👁️ @post.ViewsCount views</span>
          </div>
        </a>
      }
    }
    else
    {
      <div style="text-align:center;padding:40px;color:var(--text-2)">
        <div style="font-size:40px;margin-bottom:12px">📝</div>
        <p>No questions posted yet. Ask your first question!</p>
        <a href="/Post/Create" style="display:inline-block;margin-top:12px"><button class="btn btn-primary btn-sm">Ask a Question</button></a>
      </div>
    }
  </div>
</div>

<script>
function switchTab(el, tabId) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['tab-answers','tab-questions'].forEach(id => {
    document.getElementById(id).style.display = id === tabId ? 'flex' : 'none';
  });
}
</script>
</body>
</html>