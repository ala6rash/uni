@model Uni_Connect.Models.DashboardViewModel

@{
    Layout = null;
    string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if (span.TotalDays >= 1) return $"{(int)span.TotalDays} day{((int)span.TotalDays > 1 ? "s" : "")} ago";
        if (span.TotalHours >= 1) return $"{(int)span.TotalHours} hour{((int)span.TotalHours > 1 ? "s" : "")} ago";
        if (span.TotalMinutes >= 1) return $"{(int)span.TotalMinutes} min ago";
        return "Just now";
    }
    int ptsToTutor = Math.Max(0, 1000 - (Model.CurrentUser?.Points ?? 0));
    int ptsBarWidth = Math.Min(100, (int)(((Model.CurrentUser?.Points ?? 0) / 1000.0) * 100));
}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Home Feed — UniConnect</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
:root{--indigo:#3D52A0;--indigo-dark:#2d3f7a;--indigo-light:#EEF2FF;--violet:#7091E6;--violet-light:#EDE9FE;--amber:#F59E0B;--amber-light:#FEF3C7;--emerald:#10B981;--emerald-light:#D1FAE5;--rose:#F43F5E;--rose-light:#FFE4E6;--bg:#F8F9FF;--surface:#fff;--border:#E2E8F0;--text:#0F172A;--text-2:#64748B;--radius:12px;--sidebar:260px}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Plus Jakarta Sans',sans-serif;background:var(--bg);color:var(--text);font-size:15px}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}
.navbar{position:sticky;top:0;z-index:200;height:68px;background:rgba(255,255,255,.97);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 5%}
.nav-logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:22px;color:var(--indigo)}
.nav-logo-icon{width:38px;height:38px;background:var(--indigo);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:19px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;padding:10px 22px;border-radius:9px;font-weight:600;font-size:14px;border:none;cursor:pointer;transition:all .2s;min-height:44px;font-family:inherit;white-space:nowrap}
.btn-primary{background:var(--indigo);color:#fff}.btn-primary:hover{background:var(--indigo-dark)}
.btn-ghost{background:transparent;color:var(--indigo);border:1.5px solid var(--indigo)}.btn-ghost:hover{background:var(--indigo-light)}
.btn-sm{padding:7px 14px;font-size:13px;min-height:36px}
.chip{display:inline-flex;align-items:center;padding:3px 10px;border-radius:99px;font-size:12px;font-weight:600;white-space:nowrap}
.chip-indigo{background:var(--indigo-light);color:var(--indigo)}
.chip-violet{background:var(--violet-light);color:#5B21B6}
.chip-amber{background:var(--amber-light);color:#92400E}
.chip-emerald{background:var(--emerald-light);color:#065F46}
.chip-rose{background:var(--rose-light);color:#9F1239}
.chip-gray{background:#F1F5F9;color:var(--text-2)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;transition:box-shadow .2s,transform .2s}
.card:hover{box-shadow:0 8px 32px rgba(61,82,160,.08);transform:translateY(-2px)}
.form-input{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:9px;font-size:14px;font-family:inherit;outline:none}
.av{border-radius:50%;overflow:hidden;flex-shrink:0}
.av img{width:100%;height:100%;object-fit:cover}
.av-sm{width:36px;height:36px}
.av-md{width:44px;height:44px}
.app-wrap{display:flex;min-height:calc(100vh - 68px)}
.sidebar{width:var(--sidebar);background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:68px;height:calc(100vh - 68px);overflow-y:auto}
.sidebar-user{display:flex;align-items:center;gap:12px;padding:16px 20px 20px;border-bottom:1px solid var(--border);cursor:pointer}
.sidebar-user-name{font-weight:700;font-size:15px}
.sidebar-user-pts{font-size:12px;color:var(--amber);font-weight:600;margin-top:2px}
.sidebar-nav{padding:12px 0;flex:1;overflow-y:auto}
.nav-section{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94A3B8;padding:14px 20px 6px}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 20px;font-size:14px;font-weight:500;color:var(--text-2);cursor:pointer;transition:all .2s;border-right:3px solid transparent}
.nav-item:hover{background:var(--indigo-light);color:var(--indigo)}
.nav-item.active{background:var(--indigo-light);color:var(--indigo);font-weight:700;border-right-color:var(--indigo)}
.nav-badge{margin-left:auto;background:var(--rose);color:#fff;border-radius:99px;font-size:10px;font-weight:700;padding:1px 7px}
.ni{font-size:17px;width:22px;text-align:center}
.pts-card{margin:12px 16px;background:linear-gradient(135deg,#F59E0B,#F97316);border-radius:12px;padding:14px;color:#fff}
.main{flex:1;padding:28px 24px;min-width:0}
.right-col{width:272px;flex-shrink:0;padding:28px 20px 28px 0}
.tabs{display:flex;gap:4px;border-bottom:2px solid var(--border);margin-bottom:20px}
.tab{padding:10px 16px;font-size:14px;font-weight:600;color:var(--text-2);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;border-radius:8px 8px 0 0;transition:all .2s}
.tab:hover{color:var(--indigo);background:var(--indigo-light)}
.tab.active{color:var(--indigo);border-bottom-color:var(--indigo)}
.nav-user-dropdown{display:none;position:absolute;top:calc(100% + 8px);right:0;background:#fff;border:1px solid var(--border);border-radius:12px;padding:6px;min-width:180px;box-shadow:0 8px 32px rgba(0,0,0,.1);z-index:999}
.nav-user-dropdown.open{display:block}
.nav-dropdown-item{padding:10px 14px;font-size:13px;font-weight:600;border-radius:8px;cursor:pointer;transition:background .15s;color:var(--text);display:flex;align-items:center;gap:8px}
.nav-dropdown-item:hover{background:var(--indigo-light);color:var(--indigo)}
.hidden{display:none!important}
.fade-in{animation:fadeIn .4s ease-out}
@@keyframes fadeIn{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
</style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <a asp-controller="Dashboard" asp-action="Dashboard" class="nav-logo">
    <div class="nav-logo-icon">🎓</div>UniConnect
  </a>
  <div style="flex:1;max-width:480px;margin:0 24px">
    <input class="form-input" id="main-search" placeholder="🔍  Search questions, courses, topics..." style="min-height:40px" autocomplete="off">
  </div>
  <div style="display:flex;align-items:center;gap:10px">
    <a href="/Post/Create"><button class="btn btn-primary btn-sm">+ Ask Question</button></a>
    <a asp-action="Notifications" style="position:relative;cursor:pointer;font-size:22px;text-decoration:none">
      🔔@if(Model.UnreadNotificationsCount > 0){<div style="position:absolute;top:-4px;right:-4px;background:var(--rose);color:#fff;border-radius:99px;font-size:9px;font-weight:700;padding:1px 5px">@Model.UnreadNotificationsCount</div>}
    </a>
    <div style="position:relative">
      <div onclick="toggleUserMenu()" style="cursor:pointer;display:flex;align-items:center;gap:7px">
        <div class="av av-sm"><img src="@(Model.CurrentUser.ProfileImageUrl ?? "https://i.pravatar.cc/36?u="+Model.CurrentUser.UserID)" alt="@Model.CurrentUser.Name"></div>
        <span style="font-size:13px;font-weight:600">@Model.CurrentUser.Name ▾</span>
      </div>
      <div class="nav-user-dropdown" id="user-dropdown">
        <a asp-action="Profile"><div class="nav-dropdown-item">👤 My Profile</div></a>
        <a href="#"><div class="nav-dropdown-item">⚙️ Settings</div></a>
        <a href="#"><div class="nav-dropdown-item">🪙 Points & Rewards</div></a>
        <div style="height:1px;background:var(--border);margin:4px 0"></div>
        <form asp-controller="Login" asp-action="Logout" method="post">
          @Html.AntiForgeryToken()
          <button type="submit" style="width:100%;background:none;border:none;font-family:inherit;cursor:pointer;text-align:left">
            <div class="nav-dropdown-item" style="color:#F43F5E">🚪 Sign Out</div>
          </button>
        </form>
      </div>
    </div>
  </div>
</nav>

<div class="app-wrap">
  <!-- SIDEBAR -->
  <aside class="sidebar">
    <a asp-action="Profile" class="sidebar-user">
      <div class="av av-md"><img src="@(Model.CurrentUser.ProfileImageUrl ?? "https://i.pravatar.cc/44?u="+Model.CurrentUser.UserID)" alt="@Model.CurrentUser.Name"></div>
      <div>
        <div class="sidebar-user-name">@Model.CurrentUser.Name</div>
        <div class="sidebar-user-pts">🪙 @Model.CurrentUser.Points pts</div>
      </div>
    </a>
    <nav class="sidebar-nav">
      <div class="nav-item active"><span class="ni">🏠</span>Home Feed</div>
      <a href="/Post/Create"><div class="nav-item"><span class="ni">✏️</span>Ask a Question</div></a>
      <a href="/Sessions"><div class="nav-item"><span class="ni">💬</span>My Sessions</div></a>
      <a asp-action="Leaderboard"><div class="nav-item"><span class="ni">🏆</span>Leaderboard</div></a>
      <a href="/Points"><div class="nav-item"><span class="ni">🪙</span>Points & Rewards</div></a>
      <a asp-action="Notifications">
        <div class="nav-item"><span class="ni">🔔</span>Notifications
          @if(Model.UnreadNotificationsCount > 0){<span class="nav-badge">@Model.UnreadNotificationsCount</span>}
        </div>
      </a>
      <a asp-action="Profile"><div class="nav-item"><span class="ni">👤</span>My Profile</div></a>
      <div class="nav-section">Browse by Faculty</div>
      <div class="nav-item" style="font-size:13px;padding:8px 20px"><span class="ni">💻</span>IT<span style="margin-left:auto;font-size:11px;background:var(--indigo-light);color:var(--indigo);border-radius:99px;padding:1px 7px;font-weight:700">@(Model.RecentPosts?.Count(p=>p.Category?.Faculty == "IT Faculty") ?? 0)</span></div>
      <div class="nav-item" style="font-size:13px;padding:8px 20px"><span class="ni">⚙️</span>Engineering<span style="margin-left:auto;font-size:11px;background:var(--indigo-light);color:var(--indigo);border-radius:99px;padding:1px 7px;font-weight:700">@(Model.RecentPosts?.Count(p=>p.Category?.Faculty == "Engineering Faculty") ?? 0)</span></div>
      <div class="nav-item" style="font-size:13px;padding:8px 20px"><span class="ni">💼</span>Business<span style="margin-left:auto;font-size:11px;background:var(--indigo-light);color:var(--indigo);border-radius:99px;padding:1px 7px;font-weight:700">@(Model.RecentPosts?.Count(p=>p.Category?.Faculty == "Business Faculty") ?? 0)</span></div>
    </nav>
    <div class="pts-card">
      <div style="font-size:28px;font-weight:800;line-height:1">@Model.CurrentUser.Points</div>
      <div style="font-size:12px;opacity:.85;margin-top:2px">🪙 Your Points</div>
      <div style="background:rgba(255,255,255,.3);border-radius:99px;height:6px;margin-top:8px;overflow:hidden">
        <div style="width:@(ptsBarWidth)%;height:100%;background:#fff;border-radius:99px"></div>
      </div>
      <div style="font-size:11px;margin-top:4px;opacity:.85">@(ptsToTutor > 0 ? $"{ptsToTutor} pts to Verified Tutor" : "✓ Verified Tutor!")</div>
      <a href="/Points"><div style="font-size:12px;font-weight:700;margin-top:8px;opacity:.9;cursor:pointer">View Rewards →</div></a>
    </div>
  </aside>

  <!-- MAIN FEED -->
  <main class="main">
    <div class="tabs" id="main-tabs">
      <div class="tab active" onclick="showTab('tab-all',this)">All Questions</div>
      <div class="tab" onclick="showTab('tab-unans',this)">Unanswered</div>
      <div class="tab" onclick="showTab('tab-trending',this)">Trending 🔥</div>
      <div class="tab" onclick="showTab('tab-fac',this)">My Faculty</div>
    </div>

    <!-- ALL QUESTIONS -->
    <div id="tab-all">
      @if (Model.RecentPosts != null && Model.RecentPosts.Any())
      {
        foreach (var post in Model.RecentPosts)
        {
          bool solved = post.Answers != null && post.Answers.Any(a => a.IsAccepted);
          <a href="/Post/SinglePost/@post.PostID" style="text-decoration:none;color:inherit">
          <div class="card" style="margin-bottom:12px;cursor:pointer;position:relative">
            @if(solved){ <div style="position:absolute;top:16px;right:16px"><span class="chip chip-emerald">✓ Solved</span></div> }
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <div class="av av-sm"><img src="https://i.pravatar.cc/36?u=@post.UserID" alt="@post.User?.Name"></div>
              <span style="font-weight:600;font-size:13px">@post.User?.Name</span>
              <span style="font-size:12px;color:var(--text-2)">· @GetTimeAgo(post.CreatedAt)</span>
              <span class="chip chip-indigo" style="margin-left:auto">@(post.Category?.Faculty ?? "General")</span>
              <span class="chip chip-violet">@(post.Category?.Name ?? "General")</span>
            </div>
            <h3 style="font-size:16px;font-weight:700;margin-bottom:6px">@post.Title</h3>
            <p style="font-size:13px;color:var(--text-2);margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@post.Content</p>
            <div style="display:flex;align-items:center;gap:16px;font-size:13px;color:var(--text-2)">
              <span>👍 @post.Upvotes</span>
              <span>💬 @(post.Answers?.Count ?? 0) answers</span>
              <span>👁️ @post.ViewsCount views</span>
              @if(solved){ <button class="btn btn-ghost btn-sm" style="margin-left:auto">View Answer</button> }
              else { <button class="btn btn-primary btn-sm" style="margin-left:auto">Answer</button> }
            </div>
          </div>
          </a>
        }
      }
      else
      {
        <div style="text-align:center;padding:60px 24px;color:var(--text-2)">
          <div style="font-size:48px;margin-bottom:14px">📝</div>
          <h3 style="font-size:18px;font-weight:700;margin-bottom:8px;color:var(--text)">No questions yet</h3>
          <p style="font-size:14px;margin-bottom:18px">Be the first! Ask an academic question and earn points.</p>
          <a href="/Post/Create"><button class="btn btn-primary">Ask a Question</button></a>
        </div>
      }
    </div>

    <div id="tab-unans" class="hidden">
      @{var unanswered = Model.RecentPosts?.Where(p => p.Answers == null || !p.Answers.Any()).ToList();}
      @if(unanswered != null && unanswered.Any()){
        foreach(var post in unanswered){
          <a href="/Post/SinglePost/@post.PostID" style="text-decoration:none;color:inherit">
          <div class="card" style="margin-bottom:12px;cursor:pointer">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <div class="av av-sm"><img src="https://i.pravatar.cc/36?u=@post.UserID" alt="@post.User?.Name"></div>
              <span style="font-weight:600;font-size:13px">@post.User?.Name</span>
              <span style="font-size:12px;color:var(--text-2)">· @GetTimeAgo(post.CreatedAt)</span>
              <span class="chip chip-indigo" style="margin-left:auto">@(post.Category?.Faculty ?? "General")</span>
            </div>
            <h3 style="font-size:16px;font-weight:700;margin-bottom:6px">@post.Title</h3>
            <p style="font-size:13px;color:var(--text-2);margin-bottom:12px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@post.Content</p>
            <div style="display:flex;align-items:center;gap:16px;font-size:13px;color:var(--text-2)">
              <span>👍 @post.Upvotes</span><span>💬 0 answers</span><span>👁️ @post.ViewsCount views</span>
              <button class="btn btn-primary btn-sm" style="margin-left:auto">Be First to Answer!</button>
            </div>
          </div>
          </a>
        }
      } else {
        <div style="text-align:center;padding:40px;color:var(--text-2)"><div style="font-size:40px">✅</div><p style="margin-top:12px">All questions have been answered!</p></div>
      }
    </div>

    <div id="tab-trending" class="hidden">
      @{var trending = Model.RecentPosts?.OrderByDescending(p => p.Upvotes + (p.Answers?.Count ?? 0)).ToList();}
      @if(trending != null && trending.Any()){
        foreach(var post in trending){
          <a href="/Post/SinglePost/@post.PostID" style="text-decoration:none;color:inherit">
          <div class="card" style="margin-bottom:12px;cursor:pointer">
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
              <div class="av av-sm"><img src="https://i.pravatar.cc/36?u=@post.UserID" alt="@post.User?.Name"></div>
              <span style="font-weight:600;font-size:13px">@post.User?.Name</span>
              <span class="chip chip-indigo" style="margin-left:auto">@(post.Category?.Faculty ?? "General")</span>
            </div>
            <h3 style="font-size:16px;font-weight:700;margin-bottom:6px">@post.Title</h3>
            <div style="display:flex;align-items:center;gap:16px;font-size:13px;color:var(--text-2)">
              <span>🔥 @(post.Upvotes + (post.Answers?.Count ?? 0)) interactions</span>
              <span>💬 @(post.Answers?.Count ?? 0) answers</span>
              <button class="btn btn-primary btn-sm" style="margin-left:auto">Answer</button>
            </div>
          </div>
          </a>
        }
      }
    </div>

    <div id="tab-fac" class="hidden">
      @{var facPosts = Model.RecentPosts?.Where(p => p.Category?.Faculty == Model.CurrentUser?.Role || p.UserID == Model.CurrentUser?.UserID).ToList();}
      @if(facPosts != null && facPosts.Any()){
        foreach(var post in facPosts){
          <a href="/Post/SinglePost/@post.PostID" style="text-decoration:none;color:inherit">
          <div class="card" style="margin-bottom:12px;cursor:pointer">
            <h3 style="font-size:16px;font-weight:700;margin-bottom:6px">@post.Title</h3>
            <p style="font-size:13px;color:var(--text-2);margin-bottom:10px">@post.Content</p>
            <button class="btn btn-primary btn-sm">Answer</button>
          </div>
          </a>
        }
      } else {
        <div style="text-align:center;padding:40px;color:var(--text-2)"><p>No questions in your faculty yet.</p></div>
      }
    </div>
  </main>

  <!-- RIGHT COLUMN -->
  <div class="right-col">
    <div class="card" style="margin-bottom:14px">
      <div style="font-weight:700;margin-bottom:12px">📊 My Stats This Week</div>
      <div style="display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid var(--border)"><span style="color:var(--text-2)">Total Points</span><span style="font-weight:700;color:var(--amber)">🪙 @Model.CurrentUser.Points</span></div>
      <div style="display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid var(--border)"><span style="color:var(--text-2)">Questions</span><span style="font-weight:700">@(Model.RecentPosts?.Count(p=>p.UserID==Model.CurrentUser.UserID) ?? 0)</span></div>
      <div style="display:flex;justify-content:space-between;font-size:13px;padding:6px 0"><span style="color:var(--text-2)">Role</span><span style="font-weight:700">@Model.CurrentUser.Role</span></div>
    </div>

    <div class="card" style="margin-bottom:14px">
      <div style="font-weight:700;margin-bottom:12px">🏆 Top Contributors</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        @foreach(var topUser in Model.TopContributors){
          <div style="display:flex;align-items:center;gap:8px">
            <div class="av av-sm"><img src="https://i.pravatar.cc/36?u=@topUser.UserID" alt="@topUser.Name"></div>
            <div style="flex:1">
              <div style="font-size:13px;font-weight:600">@topUser.Name @(topUser.Points >= 1000 ? "✓" : "")</div>
              <div style="font-size:11px;color:var(--text-2)">@topUser.Role</div>
            </div>
            <span style="font-size:12px;font-weight:700;color:var(--amber)">@topUser.Points</span>
          </div>
        }
      </div>
      <div style="margin-top:12px;text-align:center"><a asp-action="Leaderboard" style="font-size:12px;color:var(--indigo);font-weight:600">View Full Leaderboard →</a></div>
    </div>

    <div class="card">
      <div style="font-weight:700;margin-bottom:10px">🔥 Trending Topics</div>
      <div style="display:flex;flex-wrap:wrap;gap:6px">
        @{var allTags = Model.RecentPosts?.SelectMany(p => new[]{p.Category?.Name ?? ""}).Where(t=>!string.IsNullOrEmpty(t)).Distinct().Take(6).ToList();}
        @if(allTags != null && allTags.Any()){
          foreach(var tag in allTags){ <span class="chip chip-indigo">@tag</span> }
        } else {
          <span class="chip chip-indigo">Data Structures</span>
          <span class="chip chip-violet">Algorithms</span>
          <span class="chip chip-gray">OOP</span>
        }
      </div>
    </div>
  </div>
</div>

<script>
function showTab(id, el) {
  document.querySelectorAll('#main-tabs .tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  ['tab-all','tab-unans','tab-trending','tab-fac'].forEach(tid => {
    const el2 = document.getElementById(tid);
    if(el2) el2.classList.toggle('hidden', tid !== id);
  });
}
function toggleUserMenu(){
  document.getElementById('user-dropdown').classList.toggle('open');
}
document.addEventListener('click', e => {
  const menu = document.querySelector('[style*="position:relative"]');
  const dropdown = document.getElementById('user-dropdown');
  if(dropdown && !e.target.closest('[onclick="toggleUserMenu()"]') && !dropdown.contains(e.target)){
    dropdown.classList.remove('open');
  }
});
// Live search
document.getElementById('main-search').addEventListener('input', function(){
  const q = this.value.toLowerCase();
  document.querySelectorAll('#tab-all .card').forEach(card => {
    const text = card.textContent.toLowerCase();
    card.parentElement.style.display = text.includes(q) ? '' : 'none';
  });
});
</script>
</body>
</html>