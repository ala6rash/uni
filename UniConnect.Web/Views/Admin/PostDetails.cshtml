@model UniConnect.Web.Models.Post

@{
    ViewData["Title"] = "Post Details";
}

<div class="container">
    <h1>Post Details</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@Model.Title</h5>
                        @if (Model.IsResolved)
                        {
                            <span class="badge bg-success">Resolved</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Open</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <p>@Model.Content</p>
                    <hr>
                    <p><strong>Author:</strong> <a asp-controller="Account" asp-action="Profile" asp-route-id="@Model.UserId">@Model.User?.FirstName @Model.User?.LastName</a></p>
                    <p><strong>Category:</strong> @Model.Category?.Name</p>
                    <p><strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                    <p><strong>Views:</strong> @Model.ViewCount</p>
                    <p><strong>Upvotes:</strong> @Model.Upvotes | <strong>Downvotes:</strong> @Model.Downvotes</p>
                </div>
                <div class="card-footer">
                    <form asp-action="DeletePost" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this post?')">Delete Post</button>
                    </form>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Answers (@Model.Comments.Count)</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Comments.Any())
                    {
                        <p class="text-muted">No answers yet.</p>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.OrderByDescending(c => c.IsBestAnswer).ThenByDescending(c => c.Upvotes))
                        {
                            <div class="mb-3 p-3 border rounded @(comment.IsBestAnswer ? "border-success bg-light" : "")">
                                @if (comment.IsBestAnswer)
                                {
                                    <span class="badge bg-success mb-2"><i class="fas fa-check"></i> Best Answer</span>
                                }
                                <p>@comment.Content</p>
                                <small class="text-muted">
                                    Answered by <a asp-controller="Account" asp-action="Profile" asp-route-id="@comment.UserId">@comment.User?.FirstName @comment.User?.LastName</a>
                                    on @comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                    | Upvotes: @comment.Upvotes | Downvotes: @comment.Downvotes
                                </small>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <a asp-controller="Posts" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary w-100 mb-2">View Public Post</a>
                    <a asp-action="Users" asp-route-id="@Model.UserId" class="btn btn-info w-100 mb-2">View Author Profile</a>
                    <form asp-action="DeletePost" asp-route-id="@Model.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Are you sure?')">Delete Post</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
