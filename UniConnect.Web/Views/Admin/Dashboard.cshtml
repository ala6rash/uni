@model UniConnect.Web.Controllers.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container">
    <h1>Admin Dashboard</h1>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-primary">@Model.TotalUsers</h3>
                    <p class="mb-0">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-success">@Model.TotalPosts</h3>
                    <p class="mb-0">Total Posts</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-info">@Model.TotalRequests</h3>
                    <p class="mb-0">Total Requests</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-warning">@Model.TotalSessions</h3>
                    <p class="mb-0">Total Sessions</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-danger">@Model.TotalReports</h3>
                    <p class="mb-0">Total Reports</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center">
                <div class="card-body">
                    <h3 class="text-secondary">@Model.PendingReports</h3>
                    <p class="mb-0">Pending Reports</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Recent Users -->
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Recent Users</h5>
                        <a asp-action="Users" class="btn btn-sm btn-primary">View All</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (!Model.RecentUsers.Any())
                    {
                        <p class="text-muted">No users yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var user in Model.RecentUsers)
                            {
                                <li class="list-group-item">
                                    <a asp-action="UserDetails" asp-route-id="@user.Id">
                                        @user.FirstName @user.LastName
                                    </a>
                                    @if (user.IsVerified)
                                    {
                                        <i class="fas fa-check-circle text-success"></i>
                                    }
                                    <br>
                                    <small class="text-muted">@user.UniversityId</small>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Posts -->
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Recent Posts</h5>
                        <a asp-action="Posts" class="btn btn-sm btn-primary">View All</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (!Model.RecentPosts.Any())
                    {
                        <p class="text-muted">No posts yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var post in Model.RecentPosts)
                            {
                                <li class="list-group-item">
                                    <a asp-action="PostDetails" asp-route-id="@post.Id">
                                        @post.Title
                                    </a>
                                    <br>
                                    <small class="text-muted">by @post.User?.FirstName @post.User?.LastName</small>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>

        <!-- Recent Reports -->
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Recent Reports</h5>
                        <a asp-action="Reports" class="btn btn-sm btn-primary">View All</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (!Model.RecentReports.Any())
                    {
                        <p class="text-muted">No reports yet.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var report in Model.RecentReports)
                            {
                                <li class="list-group-item">
                                    <a asp-action="ReportDetails" asp-route-id="@report.Id">
                                        Report #@report.Id
                                    </a>
                                    @if (report.Status == "Pending")
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@report.Status</span>
                                    }
                                    <br>
                                    <small class="text-muted">@report.CreatedAt.ToString("MMM dd, yyyy")</small>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <a asp-action="Users" class="btn btn-primary">Manage Users</a>
                    <a asp-action="Posts" class="btn btn-success">Manage Posts</a>
                    <a asp-action="Reports" class="btn btn-warning">Manage Reports</a>
                    <a asp-action="Categories" class="btn btn-info">Manage Categories</a>
                    <a asp-action="Statistics" class="btn btn-secondary">View Statistics</a>
                </div>
            </div>
        </div>
    </div>
</div>
