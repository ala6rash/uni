@model UniConnect.Web.Models.Report

@{
    ViewData["Title"] = "Report Details";
}

<div class="container">
    <h1>Report Details</h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Report #@Model.Id</h5>
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge bg-warning">Pending</span>
                        }
                        else if (Model.Status == "Resolved")
                        {
                            <span class="badge bg-success">Resolved</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Dismissed</span>
                        }
                    </div>
                </div>
                <div class="card-body">
                    <p><strong>Type:</strong> @Model.Type</p>
                    <p><strong>Reason:</strong> @Model.Reason</p>
                    <p><strong>Description:</strong> @Model.Description</p>
                    <hr>
                    <p><strong>Reporter:</strong> <a asp-action="UserDetails" asp-route-id="@Model.ReporterId">@Model.Reporter?.FirstName @Model.Reporter?.LastName</a></p>
                    <p><strong>Reported User:</strong> <a asp-action="UserDetails" asp-route-id="@Model.ReportedUserId">@Model.ReportedUser?.FirstName @Model.ReportedUser?.LastName</a></p>
                    <p><strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</p>
                    @if (Model.ReviewedAt.HasValue)
                    {
                        <p><strong>Reviewed:</strong> @Model.ReviewedAt.Value.ToString("MMMM dd, yyyy HH:mm")</p>
                        <p><strong>Status:</strong> @Model.Status</p>
                    }
                </div>
            </div>

            @if (Model.Status == "Pending")
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <form asp-action="ResolveReport" asp-route-id="@Model.Id" asp-route-action="Approve" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success w-100" onclick="return confirm('Are you sure you want to approve this report? The reported user will be warned.')">
                                        <i class="fas fa-check"></i> Approve Report
                                    </button>
                                </form>
                            </div>
                            <div class="col-md-6">
                                <form asp-action="ResolveReport" asp-route-id="@Model.Id" asp-route-action="Dismiss" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-secondary w-100" onclick="return confirm('Are you sure you want to dismiss this report?')">
                                        <i class="fas fa-times"></i> Dismiss Report
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Links</h5>
                </div>
                <div class="card-body">
                    <a asp-action="Reports" class="btn btn-primary w-100 mb-2">All Reports</a>
                    <a asp-action="UserDetails" asp-route-id="@Model.ReporterId" class="btn btn-info w-100 mb-2">View Reporter</a>
                    <a asp-action="UserDetails" asp-route-id="@Model.ReportedUserId" class="btn btn-warning w-100 mb-2">View Reported User</a>
                </div>
            </div>
        </div>
    </div>
</div>
