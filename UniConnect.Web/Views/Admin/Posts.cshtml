@model IEnumerable<UniConnect.Web.Models.Post>

@{
    ViewData["Title"] = "Manage Posts";
}

<div class="container">
    <h1>Manage Posts</h1>

    <!-- Search and Filter -->
    <div class="mb-3">
        <form asp-action="Posts" method="get" class="row g-3">
            <div class="col-md-4">
                <input type="text" name="search" class="form-control" placeholder="Search posts..." value="@ViewBag.Search">
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Views</th>
                <th>Answers</th>
                <th>Resolved</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model)
            {
                <tr>
                    <td>@post.Id</td>
                    <td>
                        <a asp-action="PostDetails" asp-route-id="@post.Id">@post.Title</a>
                    </td>
                    <td>@post.User?.FirstName @post.User?.LastName</td>
                    <td>@post.Category?.Name</td>
                    <td>@post.ViewCount</td>
                    <td>@post.Comments.Count</td>
                    <td>
                        @if (post.IsResolved)
                        {
                            <span class="badge bg-success">Resolved</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Open</span>
                        }
                    </td>
                    <td>@post.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        <a asp-action="PostDetails" asp-route-id="@post.Id" class="btn btn-sm btn-info">View</a>
                        <form asp-action="DeletePost" asp-route-id="@post.Id" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this post?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
