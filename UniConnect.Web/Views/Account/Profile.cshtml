@model UniConnect.Web.Models.User
@{
    ViewData["Title"] = "Profile";
}

<h1>My Profile</h1>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center">
                <i class="fas fa-user-circle fa-5x text-primary"></i>
                <h3 class="mt-3">@Model.FirstName @Model.LastName</h3>
                <p class="text-muted">@Model.Email</p>
                @if (Model.IsVerified)
                {
                    <span class="badge bg-success"><i class="fas fa-check"></i> Verified Tutor</span>
                }
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Profile Details</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">University ID:</dt>
                    <dd class="col-sm-8">@Model.UniversityId</dd>
                    
                    <dt class="col-sm-4">Faculty:</dt>
                    <dd class="col-sm-8">@Model.Faculty</dd>
                    
                    <dt class="col-sm-4">Bio:</dt>
                    <dd class="col-sm-8">@Model.Bio</dd>
                    
                    <dt class="col-sm-4">Member Since:</dt>
                    <dd class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy")</dd>
                </dl>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Statistics</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-3">
                        <h4 class="text-primary">@Model.Points</h4>
                        <p class="text-muted">Points</p>
                    </div>
                    <div class="col-md-3">
                        <h4 class="text-success">@Model.TotalPosts</h4>
                        <p class="text-muted">Posts</p>
                    </div>
                    <div class="col-md-3">
                        <h4 class="text-info">@Model.TotalComments</h4>
                        <p class="text-muted">Answers</p>
                    </div>
                    <div class="col-md-3">
                        <h4 class="text-warning">@Model.TotalSessions</h4>
                        <p class="text-muted">Sessions</p>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h5 class="mb-0">Rating</h5>
            </div>
            <div class="card-body text-center">
                @if (Model.TotalRatings > 0)
                {
                    <h4>
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Model.Rating)
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-warning"></i>
                            }
                        }
                        <span class="text-muted">(@Model.Rating.ToString("F1") / 5.0)</span>
                    </h4>
                    <p class="text-muted">Based on @Model.TotalRatings ratings</p>
                }
                else
                {
                    <p class="text-muted">No ratings yet</p>
                }
            </div>
        </div>
    </div>
</div>
