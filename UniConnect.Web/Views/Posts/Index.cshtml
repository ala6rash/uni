@model IEnumerable<UniConnect.Web.Models.Post>
@{
    ViewData["Title"] = "Questions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    @if (User.Identity.IsAuthenticated)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Ask Question
        </a>
    }
</div>

<div class="row mb-3">
    <div class="col-md-12">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <input type="text" name="search" class="form-control" placeholder="Search questions..." />
            <select name="category" class="form-select" style="width: 200px;">
                <option value="">All Categories</option>
                @if (ViewBag.Categories != null)
                {
                    @foreach (var category in ViewBag.Categories)
                    {
                        <option value="@category.Name">@category.Name</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-secondary">Search</button>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="list-group">
        @foreach (var post in Model)
        {
            <a asp-action="Details" asp-route-id="@post.Id" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@post.Title</h5>
                    <small>@post.CreatedAt.ToString("MMM dd, yyyy")</small>
                </div>
                <p class="mb-1">@(post.Content.Length > 100 ? post.Content.Substring(0, 100) + "..." : post.Content)</p>
                <small class="text-muted">
                    <span class="badge bg-primary">@post.Category?.Name</span>
                    By @post.User?.FirstName @post.User?.LastName |
                    <i class="fas fa-comment"></i> @post.Comments.Count answers |
                    <i class="fas fa-eye"></i> @post.ViewCount views |
                    @if (post.IsResolved)
                    {
                        <span class="badge bg-success">Resolved</span>
                    }
                </small>
            </a>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        <p class="mb-0">No questions found. Be the first to ask a question!</p>
        @if (User.Identity.IsAuthenticated)
        {
            <a asp-action="Create" class="btn btn-primary">Ask Question</a>
        }
    </div>
}
