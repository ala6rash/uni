@{
    ViewData["Title"] = "Ask Question";
}

<h1>@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label asp-for="Title" class="form-label">Question Title</label>
                <input asp-for="Title" class="form-control" placeholder="e.g., How do I solve quadratic equations?" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Category</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                    <option value="">Select a category</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Content" class="form-label">Question Details</label>
                <textarea asp-for="Content" class="form-control" rows="8" placeholder="Describe your question in detail..."></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Upload Image (optional)</label>
                <input type="file" name="image" class="form-control" accept="image/*" />
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-paper-plane"></i> Post Question
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">Tips for Good Questions</h5>
            </div>
            <div class="card-body">
                <ul>
                    <li>Be specific and clear</li>
                    <li>Include relevant details</li>
                    <li>Add images if helpful</li>
                    <li>Search for existing answers first</li>
                    <li>Use proper formatting</li>
                </ul>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header bg-warning">
                <h5 class="mb-0">Earn Points!</h5>
            </div>
            <div class="card-body">
                <p>You can earn points by:</p>
                <ul>
                    <li>Posting helpful answers (+10 points)</li>
                    <li>Getting your answer marked as best (+20 points)</li>
                    <li>Receiving upvotes (+5 points each)</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
