@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Community Dashboard — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <style>
        .dashboard-header { margin-bottom: 32px; }
        .dashboard-title { font-size: 28px; font-weight: 800; margin-bottom: 4px; }
        .dashboard-subtitle { font-size: 14px; color: var(--text-2); }
        
        .tab-container { display: flex; gap: 20px; margin-bottom: 28px; border-bottom: 2px solid var(--border); padding-bottom: 0; }
        .tab-btn {
            padding: 12px 0; background: none; border: none;
            font-size: 14px; font-weight: 600; color: var(--text-2);
            cursor: pointer; border-bottom: 3px solid transparent;
            margin-bottom: -2px; transition: all .2s;
            text-decoration: none;
        }
        .tab-btn:hover { color: var(--indigo); }
        .tab-btn.active { color: var(--indigo); font-weight: 700; border-bottom-color: var(--indigo); }
        
        .questions-list { display: flex; flex-direction: column; gap: 16px; }
        
        .q-card-enhanced {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: var(--radius); padding: 20px;
            cursor: pointer; transition: all .2s ease;
            display: block; text-decoration: none;
            color: inherit;
        }
        .q-card-enhanced:hover {
            box-shadow: var(--shadow-md); transform: translateY(-2px);
            border-color: var(--indigo);
        }
        
        .q-header {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 12px; flex-wrap: wrap;
        }
        
        .q-avatar { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; }
        
        .q-meta {
            display: flex; align-items: center; gap: 8px;
            flex-wrap: wrap; font-size: 12px;
        }
        .q-author { font-weight: 700; color: var(--text); font-size: 13px; }
        .q-date { color: var(--text-2); }
        
        .q-title {
            font-size: 15px; font-weight: 700;
            margin-bottom: 8px; line-height: 1.4;
            color: var(--text);
        }
        
        .q-content {
            font-size: 13px; color: var(--text-2);
            line-height: 1.6; margin-bottom: 12px;
        }
        
        .q-tags {
            display: flex; align-items: center; gap: 8px;
            margin-bottom: 12px; flex-wrap: wrap;
        }
        
        .q-stats {
            display: flex; gap: 16px; font-size: 13px;
            color: var(--text-2);
        }
        
        .empty-state {
            text-align: center; padding: 60px 24px;
            background: var(--surface); border-radius: var(--radius);
        }
        .empty-icon { font-size: 48px; margin-bottom: 16px; }
        .empty-title { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: var(--text); }
        .empty-text { font-size: 14px; color: var(--text-2); margin-bottom: 24px; }
    </style>
}

<div style="max-width: 1000px; margin: 0 auto;">
    <!-- Page Header -->
    <div class="dashboard-header">
        <h1 class="dashboard-title">Welcome back, @(Model.Name.Split(' ').First())! 👋</h1>
        <p class="dashboard-subtitle">See what's happening in your community today</p>
    </div>

    <!-- Tabs (Not implemented yet, placeholder) -->
    <div class="tab-container">
        <button class="tab-btn active">🏠 All Questions</button>
        <button class="tab-btn">👤 My Faculty</button>
        <button class="tab-btn">🔥 Trending</button>
    </div>

    <!-- Questions Feed -->
    <div class="questions-list">
        @{
            var posts = ViewBag.Posts as List<Post>;
            if (posts != null && posts.Count > 0)
            {
                foreach (var post in posts)
                {
                    <a asp-action="SinglePost" asp-route-id="@post.PostID" class="q-card-enhanced">
                        <!-- Header with author info -->
                        <div class="q-header">
                            <img src="https://ui-avatars.com/api/?name=@(post.User?.Name ?? "User")&background=3D52A0&color=fff" 
                                 alt="Avatar" class="q-avatar" />
                            <div>
                                <div class="q-meta">
                                    <span class="q-author">@(post.User?.Name?.Split(' ').First() ?? "User")</span>
                                    <span class="q-date">@post.CreatedAt.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>
                        </div>

                        <!-- Title -->
                        <h3 class="q-title">@post.Title</h3>

                        <!-- Preview -->
                        @if (!string.IsNullOrEmpty(post.Content))
                        {
                            <p class="q-content">
                                @{
                                    var preview = post.Content.Length > 150 ? post.Content.Substring(0, 150) + "..." : post.Content;
                                }
                                @preview
                            </p>
                        }

                        <!-- Tags/Category -->
                        <div class="q-tags">
                            @if (post.Category != null)
                            {
                                <span class="chip chip-indigo">@post.Category.Name</span>
                            }
                            @if (post.Answers?.Any(a => a.IsAccepted && !a.IsDeleted) == true)
                            {
                                <span class="chip chip-emerald">✓ Solved</span>
                            }
                        </div>

                        <!-- Stats -->
                        <div class="q-stats">
                            <span>👍 @post.Upvotes upvotes</span>
                            <span>💬 @(post.Answers?.Count(a => !a.IsDeleted) ?? 0) answers</span>
                            <span>👁️ 0 views</span>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">📝</div>
                    <h3 class="empty-title">No questions yet</h3>
                    <p class="empty-text">Be the first to ask a question in your community!</p>
                    <a asp-action="CreatePost" class="btn btn-primary">✏️ Ask a Question</a>
                </div>
            }
        }
    </div>
</div>