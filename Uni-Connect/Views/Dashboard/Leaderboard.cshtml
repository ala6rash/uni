@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Leaderboard — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    .leaderboard-wrapper { max-width: 1000px; margin: 0 auto; }
    
    .leaderboard-header {
        display: flex; justify-content: space-between;
        align-items: flex-end; margin-bottom: 32px; flex-wrap: wrap; gap: 16px;
    }
    
    .leaderboard-title { font-size: 28px; font-weight: 800; }
    .leaderboard-subtitle { font-size: 14px; color: var(--text-2); margin-top: 4px; }
    
    .leaderboard-filters { display: flex; gap: 12px; }
    .leaderboard-filters select { width: 160px; font-size: 13px; }
    
    .rank-banner {
        background: linear-gradient(90deg, var(--indigo-light), var(--violet-light));
        border: 1.5px solid #C7D7FF; border-radius: 16px;
        padding: 20px 24px; margin-bottom: 40px;
        display: flex; align-items: center; gap: 20px;
        flex-wrap: wrap;
    }
    
    .rank-banner-icon { font-size: 32px; }
    .rank-banner-content { flex: 1; min-width: 200px; }
    .rank-banner-title {
        font-weight: 800; font-size: 16px; color: var(--indigo);
        margin-bottom: 2px;
    }
    .rank-banner-text {
        font-size: 14px; color: var(--text-2); font-weight: 600;
    }
    
    .rank-banner-points { text-align: right; }
    .rank-banner-pts-num { font-weight: 900; font-size: 20px; color: var(--indigo); }
    .rank-banner-pts-label {
        font-size: 11px; text-transform: uppercase; font-weight: 800;
        color: var(--text-2); letter-spacing: 0.5px;
    }
    
    .podium-section { margin-bottom: 48px; }
    
    .podium-wrap {
        display: flex; align-items: flex-end;
        justify-content: center; gap: 16px;
        margin-bottom: 0; flex-wrap: wrap;
    }
    
    .podium-card {
        background: var(--surface); border-radius: 16px;
        padding: 24px; text-align: center;
        border: 1px solid var(--border);
        width: 180px; transition: all .2s;
    }
    
    .podium-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    
    .podium-medal { font-size: 32px; margin-bottom: 12px; }
    
    .podium-1st {
        background: linear-gradient(135deg, #FEF3C7, #FDE68A);
        border: 2px solid var(--amber); width: 220px;
        order: 2; box-shadow: 0 8px 28px rgba(245,158,11,.2);
    }
    
    .podium-2nd {
        border: 2px solid #C0C0C0; order: 1;
    }
    
    .podium-3rd {
        border: 2px solid #CD7F32; order: 3;
    }
    
    .podium-ranking-table { margin-top: 40px; }
    
    .ranking-header {
        font-size: 12px; font-weight: 700; text-transform: uppercase;
        color: var(--text-2); letter-spacing: 0.5px;
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; margin-bottom: 12px;
    }
    
    .rank-row {
        display: flex; align-items: center; gap: 12px;
        padding: 16px 20px; background: var(--surface);
        border: 1px solid var(--border);
        margin-bottom: 8px; border-radius: 12px;
        transition: all .2s; cursor: pointer;
    }
    .rank-row:hover {
        border-color: var(--indigo);
        box-shadow: var(--shadow-sm);
        transform: translateX(2px);
    }
    
    .rank-num {
        font-weight: 900; font-size: 16px;
        width: 40px; text-align: center;
    }
    
    .rank-info { flex: 1; display: flex; align-items: center; gap: 12px; }
    .rank-avatar { width: 36px; height: 36px; border-radius: 50%; }
    
    .rank-name { font-weight: 800; font-size: 14px; margin-bottom: 2px; }
    .rank-faculty { font-size: 11px; color: var(--text-2); font-weight: 600; }
    
    .rank-points { font-weight: 900; font-size: 16px; text-align: right; min-width: 80px; }
    
    .highlight-row { background: var(--indigo-light); border-color: var(--indigo); }
    .highlight-row .rank-num { color: var(--indigo); }
    .highlight-row .rank-name { color: var(--indigo); }
    .highlight-row .rank-points { color: var(--indigo); }
</style>
}

<div class="leaderboard-wrapper">
    <!-- Header -->
    <div class="leaderboard-header">
        <div>
            <h1 class="leaderboard-title">🏆 Leaderboard</h1>
            <p class="leaderboard-subtitle">Top contributors powering the community</p>
        </div>
        <div class="leaderboard-filters">
            <select class="form-input">
                <option>All Faculties</option>
                <option>IT Faculty</option>
                <option>Engineering</option>
            </select>
            <select class="form-input">
                <option>This Month</option>
                <option>This Week</option>
                <option>All Time</option>
            </select>
        </div>
    </div>

    <!-- Your Rank Banner -->
    <div class="rank-banner">
        <div class="rank-banner-icon">🏅</div>
        <div class="rank-banner-content">
            <div class="rank-banner-title">You are ranked #6 overall!</div>
            <div class="rank-banner-text">Keep helping classmates to climb higher on the leaderboard.</div>
        </div>
        <div class="rank-banner-points">
            <div class="rank-banner-pts-num">@Model.Points</div>
            <div class="rank-banner-pts-label">Total Points</div>
        </div>
    </div>

    <!-- Podium Section -->
    <div class="podium-section">
        <div class="podium-wrap">
            <!-- 2nd Place -->
            <div class="podium-card podium-2nd">
                <div class="podium-medal">🥈</div>
                <div class="av av-lg" style="margin: 0 auto 14px; border: 3px solid #C0C0C0;">
                    <img src="https://i.pravatar.cc/60?img=20" alt="Mona" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                </div>
                <div style="font-weight: 800; font-size: 15px;">Mona A.</div>
                <div style="font-size: 12px; color: var(--text-2); font-weight: 600; margin-bottom: 10px;">Business</div>
                <div style="font-size: 18px; font-weight: 900; color: var(--text);">1,080 pts</div>
            </div>

            <!-- 1st Place (Highlighted) -->
            <div class="podium-card podium-1st">
                <div class="podium-medal">🥇</div>
                <div class="av av-xl" style="margin: 0 auto 14px; border: 4px solid var(--amber);">
                    <img src="https://i.pravatar.cc/80?img=65" alt="Sami" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                </div>
                <div style="font-weight: 900; font-size: 16px;">Sami T. ✓</div>
                <span class="chip chip-emerald" style="display: inline-block; margin-bottom: 10px;">Verified Tutor</span>
                <div style="font-size: 24px; font-weight: 900; color: var(--amber);">1,240 pts</div>
            </div>

            <!-- 3rd Place -->
            <div class="podium-card podium-3rd">
                <div class="podium-medal">🥉</div>
                <div class="av av-lg" style="margin: 0 auto 14px; border: 3px solid #CD7F32;">
                    <img src="https://i.pravatar.cc/60?img=47" alt="Rania" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                </div>
                <div style="font-weight: 800; font-size: 15px;">Rania K.</div>
                <div style="font-size: 12px; color: var(--text-2); font-weight: 600; margin-bottom: 10px;">IT Faculty</div>
                <div style="font-size: 18px; font-weight: 900; color: var(--text);">960 pts</div>
            </div>
        </div>
    </div>

    <!-- Full Rankings Table -->
    <div class="podium-ranking-table">
        <div class="ranking-header"># | Student | Points</div>
        
        <!-- Highlighted: Your Rank -->
        <div class="rank-row highlight-row">
            <div class="rank-num">#6</div>
            <div class="rank-info">
                <img src="https://ui-avatars.com/api/?name=@Model.Name&background=3D52A0&color=fff&size=36" class="rank-avatar" />
                <div>
                    <div class="rank-name">@Model.Name (YOU)</div>
                    <div class="rank-faculty">@Model.Faculty</div>
                </div>
            </div>
            <div class="rank-points">@Model.Points pts</div>
        </div>

        <!-- Other Rankings -->
        <div class="rank-row">
            <div class="rank-num">#4</div>
            <div class="rank-info">
                <img src="https://i.pravatar.cc/36?img=33" class="rank-avatar" />
                <div>
                    <div class="rank-name">Khalid M.</div>
                    <div class="rank-faculty">Business</div>
                </div>
            </div>
            <div class="rank-points">912 pts</div>
        </div>

        <div class="rank-row">
            <div class="rank-num">#5</div>
            <div class="rank-info">
                <img src="https://i.pravatar.cc/36?img=48" class="rank-avatar" />
                <div>
                    <div class="rank-name">Lina H.</div>
                    <div class="rank-faculty">Engineering</div>
                </div>
            </div>
            <div class="rank-points">892 pts</div>
        </div>

        <div class="rank-row">
            <div class="rank-num">#7</div>
            <div class="rank-info">
                <img src="https://i.pravatar.cc/36?img=12" class="rank-avatar" />
                <div>
                    <div class="rank-name">Omar F.</div>
                    <div class="rank-faculty">IT Faculty</div>
                </div>
            </div>
            <div class="rank-points">845 pts</div>
        </div>

        <div class="rank-row">
            <div class="rank-num">#8</div>
            <div class="rank-info">
                <img src="https://i.pravatar.cc/36?img=25" class="rank-avatar" />
                <div>
                    <div class="rank-name">Amira S.</div>
                    <div class="rank-faculty">Law</div>
                </div>
            </div>
            <div class="rank-points">810 pts</div>
        </div>
    </div>
</div>