@model Uni_Connect.ViewModels.CreatePostViewModel
@{
    ViewData["Title"] = "Ask a Question — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<!-- CreatePost Wizard View -->
<div class="post-wizard-main">

    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a asp-action="Dashboard" asp-controller="Dashboard"><i class="fas fa-house"></i> Home</a>
        <span class="breadcrumb-sep">›</span>
        <span>Ask a Question</span>
    </div>

    <!-- Page header (hidden on success step) -->
    <div class="page-header" id="page-header">
        <h1 class="page-title"><i class="fas fa-pen"></i> Ask a Question</h1>
        <p class="page-subtitle">Help the community while earning points!</p>
    </div>

    <!-- Points Explanation Banner -->
    <div class="points-explanation-banner">
        <span class="points-explanation-icon">🪙</span>
        <div class="points-explanation-content">
            <div class="points-explanation-title">How Points Work</div>
            <div class="points-explanation-rows">
                <div class="points-row">
                    <span class="points-row-cost">−10 pts</span>
                    <span>Posting a new question</span>
                </div>
                <div class="points-row">
                    <span class="points-row-earn">+5 to +15 pts</span>
                    <span>For each helpful answer (voted by community)</span>
                </div>
                <div class="points-row">
                    <span class="points-row-earn">+10 pts</span>
                    <span>For marking an answer as "Best Answer"</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Wizard progress bar -->
    <div class="wizard-wrap" id="wizard-bar">
        <div class="wizard-steps">
            <div class="wz-step active" id="ws1">
                <div class="wz-num">1</div>
                <span class="wz-label">Search First</span>
            </div>
            <div class="wz-step" id="ws2">
                <div class="wz-num">2</div>
                <span class="wz-label">Write Question</span>
            </div>
            <div class="wz-step" id="ws3">
                <div class="wz-num">3</div>
                <span class="wz-label">Preview & Post</span>
            </div>
        </div>
        <div class="wizard-progress">
            <div class="wizard-progress-fill" id="wz-progress"></div>
        </div>
    </div>

    <!-- STEP 1 — SEARCH FIRST -->
    <div class="fade-in" id="wz1">
        <div class="card search-card">
            <div class="search-card-header">
                <div class="search-icon-box"><i class="fas fa-magnifying-glass"></i></div>
                <div>
                    <div class="search-prompt-title">Check if your question already exists</div>
                    <div class="search-prompt-desc">
                        Search first — you might find an instant answer and save your
                        <strong class="points-highlight">10 pts</strong>.
                        Most questions have already been answered!
                    </div>
                </div>
            </div>
            <div class="search-input-row">
                <input autocomplete="off" class="form-input search-field" id="s1-search"
                       oninput="step1Search(this.value)"
                       placeholder="e.g. AVL tree rotation, trial balance, eigenvalues..." />
                <button type="button" class="btn btn-ghost btn-sm"
                        onclick="step1Search(document.getElementById('s1-search').value)">
                    <i class="fas fa-magnifying-glass"></i> Search
                </button>
            </div>
        </div>

        <div class="hidden" id="s1-results">
            <div class="search-results-label">
                <span><i class="fas fa-clipboard"></i> Similar questions found — check these first:</span>
            </div>
            <div id="s1-results-list"></div>
            <div class="search-answer-tip">
                <span class="search-tip-icon"><i class="fas fa-lightbulb"></i></span>
                <p class="amber-tip-text">
                    Is your question answered above?
                    <a class="amber-tip-link" href="#">Click to view the full answer</a>
                    and save your 10 pts!
                </p>
            </div>
        </div>

        <div class="hidden search-no-results" id="s1-no-results">
            <span class="search-no-results-icon"><i class="fas fa-check-circle"></i></span>
            <p class="search-no-results-text">No similar questions found — yours is unique! Go ahead and post it.</p>
        </div>

        <div class="wizard-step-actions">
            <a href="@Url.Action("Dashboard", "Dashboard")"><button type="button" class="btn btn-ghost">← Cancel</button></a>
            <button type="button" class="btn btn-primary btn-lg" onclick="goToStep2()">
                My question is different → <span class="btn-cost-label">(−10 pts)</span>
            </button>
        </div>
    </div>

    <!-- STEP 2 — WRITE QUESTION -->
    <div class="hidden" id="wz2">
        <form id="create-post-form" method="post" asp-action="CreatePost" asp-controller="Dashboard">
            <div class="card">
                <!-- Title -->
                <div class="form-group">
                    <label class="form-label">Question Title <span class="form-label-req">*</span></label>
                    <input class="form-input" id="s2-title" asp-for="Title" maxlength="150"
                           oninput="updateTitle(); updateCharCount('s2-title', 'tc-title', 10, 150)"
                           placeholder="Start with How, Why, What, When, Where..." />
                    <div class="form-field-footer">
                        <div class="form-hint">Be specific — good: "How does AVL tree LL rotation work?" · bad: "help with AVL"</div>
                        <div class="char-counter char-counter-right" id="tc-title">0/150</div>
                    </div>
                    <div class="form-error" id="err-title">⚠ Please enter a question title (minimum 10 characters)</div>
                </div>

                <!-- Faculty + Course grid -->
                <div class="faculty-course-grid">
                    <div>
                        <label class="form-label">Faculty <span class="form-label-req">*</span></label>
                        <select class="form-input form-select" id="s2-faculty" asp-for="Faculty" onchange="updatePreview()">
                            <option value="">Select your faculty...</option>
                            <option value="IT Faculty"><i class="fas fa-laptop"></i> Information Technology</option>
                            <option value="Engineering"><i class="fas fa-cog"></i> Engineering &amp; Technology</option>
                            <option value="Business"><i class="fas fa-briefcase"></i> Business &amp; Finance</option>
                            <option value="Law"><i class="fas fa-scale-balanced"></i> Faculty of Law</option>
                            <option value="Arts"><i class="fas fa-palette"></i> Arts &amp; Educational Sciences</option>
                            <option value="Pharmacy"><i class="fas fa-prescription-bottle"></i> Faculty of Pharmacy</option>
                            <option value="Administrative"><i class="fas fa-chart-bar"></i> Administrative Sciences</option>
                        </select>
                        <div class="form-error" id="err-faculty">⚠ Please select your faculty</div>
                    </div>
                    <div>
                        <label class="form-label">Course Code <span class="form-label-req">*</span></label>
                        <input class="form-input" id="s2-course" asp-for="CourseCode" maxlength="10"
                               oninput="updatePreview()" placeholder="e.g. CS302, MATH201" />
                        <div class="form-hint">The code of the course this question is about (e.g., CS302, ACCT101)</div>
                        <div class="form-error" id="err-course">⚠ Please enter the course code</div>
                    </div>
                </div>

                <!-- Content -->
                <div class="form-group">
                    <label class="form-label">Describe Your Question <span class="form-label-req">*</span></label>
                    <textarea class="form-input form-textarea" id="s2-body" asp-for="Content" maxlength="2000"
                              oninput="updateBody(); updateCharCount('s2-body', 'tc-body', 50, 2000)"
                              placeholder="Explain your question clearly: • What are you trying to understand? • What have you tried? • Where are you stuck?"></textarea>
                    <div class="form-field-footer">
                        <div class="form-hint">Minimum 50 characters — more detail gets faster, better answers</div>
                        <div class="char-counter char-counter-right" id="tc-body">0/2000</div>
                    </div>
                    <div class="form-error" id="err-body">⚠ Please describe your question (minimum 50 characters)</div>
                </div>

                <!-- Image Upload -->
                <div class="form-group">
                    <label class="form-label">
                        Attach Image <span class="form-label-note">(optional)</span>
                    </label>
                    <div class="file-upload-wrapper">
                        <input class="file-upload-input" id="image-input" type="file" accept="image/*" onchange="handleFileSelect(event)" />
                        <label for="image-input" class="file-upload-label" id="upload-label">
                            <span class="file-upload-icon">📸</span>
                            <span class="file-upload-text">Click to upload or drag image here</span>
                            <span class="file-upload-hint">JPG, PNG, WebP • Max 5MB</span>
                        </label>
                        <div class="file-preview hidden" id="file-preview">
                            <img id="preview-img" class="file-preview-img" alt="Preview" />
                            <div class="file-preview-info">
                                <div class="file-preview-name" id="preview-name"></div>
                                <div class="file-preview-size" id="preview-size"></div>
                            </div>
                            <button type="button" class="file-preview-remove" onclick="removeFile()">Remove</button>
                        </div>
                    </div>
                    <div class="form-hint">Adding a screenshot or diagram can greatly help others understand your question</div>
                </div>

                <!-- Tags -->
                <div class="form-group tags-form-group">
                    <label class="form-label">
                        Tags <span class="form-label-note">(optional, max 5)</span>
                    </label>
                    <div class="form-hint" style="margin-bottom: 10px;">Add relevant topics to help others find your question. Examples: AVL trees, binary search, data structures</div>
                    <div class="tags-wrap" id="tags-wrap"
                         onclick="document.getElementById('tags-input').focus()">
                        <input class="tags-input" id="tags-input" maxlength="20"
                               onkeydown="handleTagInput(event)"
                               placeholder="Type a tag and press Enter..." type="text" />
                    </div>
                    <div class="form-hint">Press Enter or comma to add a tag</div>
                </div>
            </div>

            <div class="wizard-step-actions">
                <button type="button" class="btn btn-ghost" onclick="goToStep1()">← Back</button>
                <button type="button" class="btn btn-primary btn-lg" id="btn-preview" onclick="goToStep3()">Preview Question →</button>
            </div>
        </form>
    </div>

    <!-- STEP 3 — PREVIEW & POST -->
    <div class="hidden" id="wz3">
        <div class="posting-cost-banner">
            <span class="posting-cost-icon"><i class="fas fa-coins"></i></span>
            <div>
                <div class="posting-cost-title">This will cost 10 points</div>
                <div class="amber-tip-text">
                    Posting a question costs 10 pts. <strong>Best answers earn +15 pts back!</strong>
                </div>
            </div>
        </div>

        <div class="preview-section-label"><i class="fas fa-eye"></i> Preview — this is how your question will look:</div>

        <div class="card preview-post-card">
            <div class="preview-post-meta">
                <div class="av av-sm"><img alt="User" src="https://api.dicebear.com/7.x/avataaars/svg?seed=user" /></div>
                <span class="preview-author-name">You</span>
                <span class="preview-post-time">· Just now</span>
                <span class="chip chip-indigo preview-faculty-badge" id="prev-faculty-chip"></span>
                <span class="chip chip-gray" id="prev-course-chip"></span>
            </div>
            <div class="preview-post-title" id="prev-title">Your question title will appear here...</div>
            <div class="preview-post-body" id="prev-body">Your question description will appear here...</div>
            <div class="preview-post-tags" id="prev-tags"></div>
            <div class="preview-post-stats">
                <span><i class="fas fa-thumbs-up"></i> 0</span>
                <span><i class="fas fa-comments"></i> 0 answers</span>
                <span><i class="fas fa-eye"></i> 0 views</span>
                <span class="chip chip-gray preview-status-chip">Open</span>
            </div>
        </div>

        <div class="card checklist-card">
            <div class="checklist-heading"><i class="fas fa-check-circle"></i> Before you post — quick checklist:</div>
            <div class="checklist-items">
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk1" type="checkbox" />
                    My question title is clear and specific
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk2" type="checkbox" />
                    I described what I already tried and where I'm stuck
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk3" type="checkbox" />
                    The faculty and course code are correct
                </label>
                <label class="checklist-item">
                    <input class="checklist-checkbox" id="chk4" type="checkbox" />
                    I searched first and this question doesn't already exist
                </label>
            </div>
        </div>

        <div class="wizard-step-actions">
            <button type="button" class="btn btn-ghost" onclick="goToStep2()">← Edit Question</button>
            <button type="button" class="btn btn-primary btn-lg" id="btn-post" onclick="postQuestion()">
                <i class="fas fa-rocket"></i> Post Question <span class="btn-cost-label">(−10 pts)</span>
            </button>
        </div>
    </div>

    <!-- STEP 4 — SUCCESS -->
    <div class="hidden fade-in" id="wz4">
        <div class="card success-card-body">
            <div class="success-icon-circle"><i class="fas fa-party-popper" style="font-size:48px"></i></div>
            <h2 class="success-heading">Question posted!</h2>
            <p class="success-description">Your question is now live. The community will start answering soon.</p>
            <p class="success-points-summary">
                You were charged <strong class="cost-deducted">−10 pts</strong>.
            </p>

            <div class="earn-back-panel">
                <div class="earn-back-heading"><i class="fas fa-coins" style="margin-right:8px"></i>How to earn your points back:</div>
                <div class="earn-ways-list">
                    <span><i class="fas fa-thumbs-up" style="margin-right:8px"></i>Every upvote on any of your answers = <strong>+10 pts</strong></span>
                    <span><i class="fas fa-check-circle" style="margin-right:8px"></i>If your answer is marked Best Answer = <strong>+15 pts</strong></span>
                    <span><i class="fas fa-graduation-cap" style="margin-right:8px"></i>Accept a tutoring session = <strong>+20 pts</strong></span>
                </div>
            </div>

            <div class="success-action-buttons">
                <a asp-action="Dashboard" asp-controller="Dashboard"><button type="button" class="btn btn-primary btn-lg">Back to Home Feed</button></a>
            </div>
        </div>
    </div>

</div>

<!-- Wizard JavaScript -->
<script>
    // State
    const state = { title: '', faculty: '', course: '', body: '', tags: [] };
    const tags = [];

    // Character counter
    function updateCharCount(inputId, counterId, min, max) {
        const inp = document.getElementById(inputId);
        const cnt = document.getElementById(counterId);
        if (!inp || !cnt) return;
        const len = inp.value.length;
        cnt.textContent = len + '/' + max;
        cnt.className = 'char-counter char-counter-right';
        if (len === 0) return;
        if (len < min) cnt.classList.add('char-err');
        else if (len > max * 0.85) cnt.classList.add('char-warn');
        else cnt.classList.add('char-ok');
    }

    // Wizard progress
    function setProgress(step) {
        const pct = { 1: 16, 2: 50, 3: 83, 4: 100 }[step] || 16;
        const bar = document.getElementById('wz-progress');
        if (bar) bar.style.width = pct + '%';
    }

    // Step switcher
    function switchToStep(n) {
        [1, 2, 3, 4].forEach(i => {
            const el = document.getElementById('wz' + i);
            if (el) el.classList.add('hidden');
        });
        [1, 2, 3].forEach(i => {
            const dot = document.getElementById('ws' + i);
            if (!dot) return;
            dot.classList.remove('active', 'done');
            if (i === n) dot.classList.add('active');
            if (i < n) dot.classList.add('done');
        });
        const target = document.getElementById('wz' + n);
        if (target) {
            target.classList.remove('hidden');
            target.classList.add('fade-in');
        }
        const isSuccess = n === 4;
        const wb = document.getElementById('wizard-bar');
        const ph = document.getElementById('page-header');
        if (wb) wb.style.display = isSuccess ? 'none' : '';
        if (ph) ph.style.display = isSuccess ? 'none' : '';
        setProgress(n);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // Sample questions
    const SAMPLE_QUESTIONS = [
        { title: 'How does AVL tree rotation actually work?', course: 'CS302', faculty: 'IT', solved: true, answers: 7, votes: 42 },
        { title: 'What is the time complexity of AVL tree operations?', course: 'CS302', faculty: 'IT', solved: true, answers: 4, votes: 18 },
        { title: 'Difference between Dijkstra and Bellman-Ford?', course: 'CS401', faculty: 'IT', solved: false, answers: 4, votes: 18 },
        { title: 'How to prepare a trial balance from journal entries?', course: 'ACCT201', faculty: 'Business', solved: true, answers: 3, votes: 9 },
        { title: 'Finding eigenvalues of a 3×3 matrix step by step?', course: 'MATH201', faculty: 'Engineering', solved: false, answers: 5, votes: 14 },
    ];

    // Step 1: Search
    function step1Search(q) {
        const resultsPanel = document.getElementById('s1-results');
        const noResults = document.getElementById('s1-no-results');
        const list = document.getElementById('s1-results-list');
        q = q.trim().toLowerCase();

        if (q.length < 3) {
            if (resultsPanel) resultsPanel.classList.add('hidden');
            if (noResults) noResults.classList.add('hidden');
            return;
        }

        const matches = SAMPLE_QUESTIONS.filter(x =>
            x.title.toLowerCase().includes(q) ||
            x.course.toLowerCase().includes(q)
        );

        if (matches.length && list) {
            list.innerHTML = '';
            matches.slice(0, 3).forEach(m => {
                const el = document.createElement('a');
                el.href = '#';
                el.style.cssText = 'display:block;background:#fff;border:1.5px solid var(--border);border-radius:12px;padding:14px 18px;margin-bottom:10px;text-decoration:none;cursor:pointer;color:inherit;transition:all .2s';
                el.onmouseover = () => { el.style.borderColor = 'var(--indigo)'; el.style.boxShadow = '0 4px 16px rgba(61,82,160,.12)'; el.style.transform = 'translateY(-1px)'; };
                el.onmouseout = () => { el.style.borderColor = 'var(--border)'; el.style.boxShadow = 'none'; el.style.transform = 'none'; };
                el.innerHTML = `
                    <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px">
                        <span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:${m.solved ? 'var(--emerald-light)' : '#EEF2FF'};color:${m.solved ? '#065F46' : 'var(--indigo)'}"><i class="${m.solved ? 'fas fa-check-circle' : 'fas fa-circle-question'}" style="font-size:10px"></i> ${m.solved ? 'Solved' : 'Open'}</span>
                        <span style="display:inline-flex;align-items:center;padding:3px 10px;border-radius:99px;font-size:11px;font-weight:700;background:var(--violet-light);color:#5B21B6">${escapeHtml(m.course)}</span>
                        <span style="font-size:11px;color:var(--text-2);margin-left:auto">${m.answers} answers · ${m.votes} votes</span>
                    </div>
                    <div style="font-size:14px;font-weight:700;color:var(--indigo)">${escapeHtml(m.title)}</div>`;
                list.appendChild(el);
            });
            if (resultsPanel) resultsPanel.classList.remove('hidden');
            if (noResults) noResults.classList.add('hidden');
        } else {
            if (resultsPanel) resultsPanel.classList.add('hidden');
            if (noResults) noResults.classList.remove('hidden');
        }
    }

    function goToStep1() { switchToStep(1); }
    function goToStep2() { switchToStep(2); }

    // Step 2: Validation
    function validateStep2() {
        let ok = true;
        const title = document.getElementById('s2-title').value.trim();
        const faculty = document.getElementById('s2-faculty').value;
        const course = document.getElementById('s2-course').value.trim();
        const body = document.getElementById('s2-body').value.trim();

        function check(inputId, errId, value, minLen) {
            const inp = document.getElementById(inputId);
            const err = document.getElementById(errId);
            if (value.length < minLen) {
                if (inp) inp.classList.add('error');
                if (err) err.style.display = 'block';
                ok = false;
            } else {
                if (inp) { inp.classList.remove('error'); inp.classList.add('success'); }
                if (err) err.style.display = 'none';
            }
        }
        check('s2-title', 'err-title', title, 10);
        check('s2-faculty', 'err-faculty', faculty, 1);
        check('s2-course', 'err-course', course, 2);
        check('s2-body', 'err-body', body, 50);
        return ok;
    }

    function goToStep3() {
        if (!validateStep2()) {
            showToast('⚠️ Please fix the errors above', 'warn');
            const err = document.querySelector('.form-input.error');
            if (err) err.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
        }
        state.title = document.getElementById('s2-title').value.trim();
        state.faculty = document.getElementById('s2-faculty').value;
        state.course = document.getElementById('s2-course').value.trim();
        state.body = document.getElementById('s2-body').value.trim();
        updatePreview();
        switchToStep(3);
    }

    // Preview
    function updateTitle() {
        state.title = document.getElementById('s2-title').value;
        updatePreview();
    }
    function updateBody() {
        state.body = document.getElementById('s2-body').value;
        updatePreview();
    }
    function updatePreview() {
        state.faculty = document.getElementById('s2-faculty').value;
        state.course = document.getElementById('s2-course').value;
        const fChip = document.getElementById('prev-faculty-chip');
        const cChip = document.getElementById('prev-course-chip');
        const prevTitle = document.getElementById('prev-title');
        const prevBody = document.getElementById('prev-body');
        if (fChip) fChip.textContent = state.faculty || 'Faculty';
        if (cChip) cChip.textContent = state.course || 'Course';
        if (prevTitle) prevTitle.textContent = state.title || 'Your question title will appear here...';
        if (prevBody) prevBody.textContent = state.body || 'Your question description will appear here...';
        updateTagPreview();
    }

    // Tags
    function handleTagInput(e) {
        const inp = document.getElementById('tags-input');
        if ((e.key === 'Enter' || e.key === ',') && inp) {
            e.preventDefault();
            addTag(inp.value.replace(',', '').trim());
            inp.value = '';
        }
        if (e.key === 'Backspace' && inp && inp.value === '' && tags.length) {
            removeTag(tags.length - 1);
        }
    }
    function addTag(val) {
        if (!val || tags.length >= 5 || tags.includes(val)) return;
        tags.push(val);
        renderTags();
        updateTagPreview();
    }
    function removeTag(i) {
        tags.splice(i, 1);
        renderTags();
        updateTagPreview();
    }
    function renderTags() {
        const wrap = document.getElementById('tags-wrap');
        const inp = document.getElementById('tags-input');
        if (!wrap) return;
        wrap.querySelectorAll('.tag-chip').forEach(t => t.remove());
        tags.forEach((t, i) => {
            const chip = document.createElement('div');
            chip.className = 'tag-chip';
            chip.innerHTML = `${escapeHtml(t)}<button type="button" onclick="removeTag(${i})">×</button>`;
            wrap.insertBefore(chip, inp);
        });
    }
    function updateTagPreview() {
        const container = document.getElementById('prev-tags');
        if (!container) return;
        container.innerHTML = '';
        tags.forEach(t => {
            const chip = document.createElement('span');
            chip.className = 'chip chip-gray';
            chip.style.fontSize = '12px';
            chip.textContent = t;
            container.appendChild(chip);
        });
    }

    // Step 3: Post
    function postQuestion() {
        const unchecked = ['chk1', 'chk2', 'chk3', 'chk4'].filter(id => !document.getElementById(id).checked);
        if (unchecked.length) {
            showToast('⚠️ Please check all boxes before posting', 'warn');
            return;
        }
        const form = document.getElementById('create-post-form');
        if (form) form.submit();
    }

    // Toast
    function showToast(msg, type = '') {
        document.querySelector('.toast')?.remove();
        const el = document.createElement('div');
        el.className = 'toast' + (type ? ' toast-' + type : '');
        el.innerHTML = msg;
        document.body.appendChild(el);
        setTimeout(() => {
            el.style.opacity = '0';
            el.style.transition = 'opacity .4s';
            setTimeout(() => el.remove(), 400);
        }, 3500);
    }

    // Utility
    function escapeHtml(str) {
        return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // Init
    document.addEventListener('DOMContentLoaded', () => {
        setProgress(1);
    });

    // File upload handling
    function handleFileSelect(event) {
        const file = event.target.files[0];
        if (!file) return;

        // Validate file type
        if (!['image/jpeg', 'image/png', 'image/webp'].includes(file.type)) {
            showToast('⚠️ Please upload a JPG, PNG, or WebP image', 'warn');
            document.getElementById('image-input').value = '';
            return;
        }

        // Validate file size (5MB)
        if (file.size > 5 * 1024 * 1024) {
            showToast('⚠️ Image must be smaller than 5MB', 'warn');
            document.getElementById('image-input').value = '';
            return;
        }

        // Show preview
        const reader = new FileReader();
        reader.onload = (e) => {
            const preview = document.getElementById('file-preview');
            const img = document.getElementById('preview-img');
            const name = document.getElementById('preview-name');
            const size = document.getElementById('preview-size');

            img.src = e.target.result;
            name.textContent = file.name;
            size.textContent = (file.size / 1024).toFixed(1) + ' KB';
            preview.classList.remove('hidden');
            document.getElementById('upload-label').style.display = 'none';
        };
        reader.readAsDataURL(file);
    }

    function removeFile() {
        document.getElementById('image-input').value = '';
        document.getElementById('file-preview').classList.add('hidden');
        document.getElementById('upload-label').style.display = '';
    }

    // Drag and drop for file upload
    const uploadLabel = document.getElementById('upload-label');
    if (uploadLabel) {
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            uploadLabel.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        ['dragenter', 'dragover'].forEach(eventName => {
            uploadLabel.addEventListener(eventName, () => {
                uploadLabel.style.borderColor = 'var(--indigo)';
                uploadLabel.style.background = 'var(--indigo-light)';
            });
        });

        ['dragleave', 'drop'].forEach(eventName => {
            uploadLabel.addEventListener(eventName, () => {
                uploadLabel.style.borderColor = '';
                uploadLabel.style.background = '';
            });
        });

        uploadLabel.addEventListener('drop', (e) => {
            const dt = e.dataTransfer;
            const files = dt.files;
            document.getElementById('image-input').files = files;
            if (files.length > 0) handleFileSelect({ target: { files } });
        });
    }
</script>
