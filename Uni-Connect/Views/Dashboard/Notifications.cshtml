@model Uni_Connect.Models.User
@{
    ViewData["Title"] = "Notifications — UniConnect";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-container">
    <div class="page-header">
        <h1 class="page-title"><i class="fas fa-bell"></i> Notifications</h1>
        <p class="page-subtitle">Stay updated with your activity and discussions</p>
    </div>

    <div class="notifications-container">
        @if (Model?.Notifications?.Any() == true)
        {
            <div class="card">
                <div class="notifications-list">
                    @foreach (var notif in Model.Notifications.OrderByDescending(n => n.CreatedAt))
                    {
                        <div class="notification-item">
                            <div class="notification-icon">
                                @if (notif.Type == "Answer")
                                {
                                    <i class="fas fa-comment-dots" style="color:var(--indigo)"></i>
                                }
                                else if (notif.Type == "Upvote")
                                {
                                    <i class="fas fa-thumbs-up" style="color:var(--amber)"></i>
                                }
                                else
                                {
                                    <i class="fas fa-star" style="color:var(--violet)"></i>
                                }
                            </div>
                            <div class="notification-content">
                                <div class="notification-title">@notif.Message</div>
                                <div class="notification-time">@notif.CreatedAt.ToString("MMMM d · h:mm tt")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="card" style="text-align:center;padding:60px 30px">
                <div style="font-size:48px;margin-bottom:16px"><i class="fas fa-inbox" style="color:var(--text-2)"></i></div>
                <h3 style="margin-bottom:8px;font-size:18px">No notifications yet</h3>
                <p style="color:var(--text-2);font-size:14px">When someone answers your question or upvotes, you'll see it here</p>
            </div>
        }
    </div>
</div>

<style>
    .page-container { max-width: 800px; margin: 0 auto; padding: 24px 20px; }
    .page-header { margin-bottom: 32px; }
    .page-title { font-size: 28px; font-weight: 800; color: var(--text); margin-bottom: 8px; }
    .page-subtitle { font-size: 15px; color: var(--text-2); }
    
    .notifications-container { display: flex; flex-direction: column; gap: 16px; }
    
    .notifications-list { display: flex; flex-direction: column; }
    .notification-item { display: flex; gap: 16px; padding: 16px 18px; border-bottom: 1px solid var(--border); transition: background .2s; }
    .notification-item:hover { background: var(--indigo-light); }
    .notification-item:last-child { border-bottom: none; }
    
    .notification-icon { font-size: 20px; flex-shrink: 0; margin-top: 2px; }
    .notification-content { flex: 1; }
    .notification-title { font-size: 14px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
    .notification-time { font-size: 12px; color: var(--text-2); }
</style>
