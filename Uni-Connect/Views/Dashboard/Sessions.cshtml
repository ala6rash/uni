@model List<Uni_Connect.Models.PrivateSession>
@{
    ViewData["Title"] = "Private Sessions";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <!-- Header -->
    <div style="margin-bottom: 30px;">
        <h1 style="font-size: 32px; font-weight: 800; color: #0F172A; margin: 0 0 8px 0;">
            Private Sessions 💬
        </h1>
        <p style="font-size: 15px; color: #64748B; margin: 0;">
            One-on-one conversations with students and helpers
        </p>
    </div>

    <!-- Sessions List -->
    @if (Model != null && Model.Count > 0)
    {
        <div style="display: grid; gap: 16px;">
            @foreach (var session in Model.OrderByDescending(s => s.CreatedAt))
            {
                var isStudent = true; // You'll need to get the current user ID to determine this
                var otherUser = isStudent ? session.Helper : session.Student;
                var lastMessage = session.Messages?.OrderByDescending(m => m.SentAt).FirstOrDefault();

                <div style="background: white; border: 1.5px solid #E2E8F0; border-radius: 12px; padding: 20px; cursor: pointer; transition: all 0.2s;" 
                     onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 8px 20px rgba(61,82,160,0.08)'; this.style.borderColor='#3D52A0'"
                     onmouseout="this.style.transform='none'; this.style.boxShadow='none'; this.style.borderColor='#E2E8F0'">
                    
                    <div style="display: flex; gap: 16px; align-items: center;">
                        <!-- Avatar -->
                        <img src="https://ui-avatars.com/api/?name=@(otherUser?.Name ?? "User")&background=3D52A0&color=fff&size=56" 
                             alt="User" style="width: 56px; height: 56px; border-radius: 50%; flex-shrink: 0;" />
                        
                        <!-- Session Info -->
                        <div style="flex: 1; min-width: 0;">
                            <h3 style="font-size: 16px; font-weight: 800; color: #0F172A; margin: 0 0 4px 0;">
                                @(otherUser?.Name ?? "Unknown")
                            </h3>
                            <p style="font-size: 13px; color: #64748B; margin: 0 0 8px 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @if (lastMessage != null)
                                {
                                    @lastMessage.MessageText
                                }
                                else
                                {
                                    <text>No messages yet</text>
                                }
                            </p>
                            <span style="font-size: 12px; color: #94A3B8;">
                                @session.CreatedAt.ToString("MMM dd, yyyy")
                            </span>
                        </div>

                        <!-- Message Count Badge -->
                        <div style="text-align: center; flex-shrink: 0;">
                            <div style="background: #3D52A0; color: white; width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px;">
                                @(session.Messages?.Count(m => !m.IsDeleted) ?? 0)
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div style="text-align: center; padding: 80px 20px; background: white; border-radius: 12px;">
            <p style="font-size: 18px; font-weight: 700; color: #0F172A; margin: 0 0 12px 0;">
                No sessions yet 📭
            </p>
            <p style="font-size: 14px; color: #64748B; margin: 0 0 30px 0;">
                Start a session by asking a question or helping another student
            </p>
            <a asp-action="CreatePost" style="background: linear-gradient(135deg, #3D52A0 0%, #7091E6 100%); color: white; padding: 12px 30px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 14px; display: inline-block;">
                ✏️ Ask Question
            </a>
        </div>
    }
</div>
