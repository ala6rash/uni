@model Uni_Connect.Controllers.DatabaseViewerViewModel

@{
    ViewData["Title"] = "Database Viewer";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UniConnect - Database Viewer</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            background: white;
            padding: 30px;
            border-radius: 12px;
            margin-bottom: 30px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }

        .header h1 {
            color: #667eea;
            font-size: 32px;
            margin-bottom: 10px;
        }

        .header p {
            color: #666;
            font-size: 16px;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }

        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
        }

        .stat-card .number {
            font-size: 36px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .stat-card .label {
            font-size: 14px;
            opacity: 0.9;
        }

        .tables-container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
            margin-bottom: 30px;
        }

        .table-section {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .table-section h2 {
            color: #667eea;
            font-size: 22px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #667eea;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        thead {
            background: #f8f9fa;
            border-bottom: 2px solid #ddd;
        }

        th {
            padding: 12px;
            text-align: left;
            font-weight: 600;
            color: #333;
            white-space: nowrap;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid #eee;
            color: #666;
            word-break: break-word;
            max-width: 300px;
        }

        tr:hover {
            background-color: #f9f9f9;
        }

        .empty-message {
            padding: 40px;
            text-align: center;
            color: #999;
            font-size: 16px;
        }

        .footer {
            background: white;
            padding: 20px;
            border-radius: 12px;
            text-align: center;
            color: #666;
            margin-top: 20px;
        }

        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            background: #e3f2fd;
            color: #1976d2;
        }

        .date-time {
            color: #999;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>📊 UniConnect Database Viewer</h1>
            <p>Live view of all database contents</p>
            
            <div class="stats">
                <div class="stat-card">
                    <div class="number">@Model.UserCount</div>
                    <div class="label">👥 Users</div>
                </div>
                <div class="stat-card">
                    <div class="number">@Model.PostCount</div>
                    <div class="label">📝 Posts</div>
                </div>
                <div class="stat-card">
                    <div class="number">@Model.CategoryCount</div>
                    <div class="label">📂 Categories</div>
                </div>
                <div class="stat-card">
                    <div class="number">@Model.TagCount</div>
                    <div class="label">🏷️ Tags</div>
                </div>
            </div>
        </div>

        <div class="tables-container">
            <!-- USERS TABLE -->
            <div class="table-section">
                <h2>👥 Users (@Model.UserCount)</h2>
                @if (Model.Users.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Points</th>
                                <th>Registered</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model.Users.OrderBy(u => u.UserID))
                            {
                                <tr>
                                    <td><strong>@user.UserID</strong></td>
                                    <td>@user.Username</td>
                                    <td>@user.Email</td>
                                    <td><span class="badge">@user.Points pts</span></td>
                                    <td><span class="date-time">@user.CreatedAt?.ToString("yyyy-MM-dd")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-message">No users found</div>
                }
            </div>

            <!-- POSTS TABLE -->
            <div class="table-section">
                <h2>📝 Posts (@Model.PostCount)</h2>
                @if (Model.Posts.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Title</th>
                                <th>User ID</th>
                                <th>Category</th>
                                <th>Posted</th>
                                <th>Views</th>
                                <th>Upvotes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var post in Model.Posts.OrderByDescending(p => p.PostID))
                            {
                                <tr>
                                    <td><strong>@post.PostID</strong></td>
                                    <td>@post.Title?.Substring(0, Math.Min(60, post.Title?.Length ?? 0))@(post.Title?.Length > 60 ? "..." : "")</td>
                                    <td>@post.UserID</td>
                                    <td>@post.CategoryID</td>
                                    <td><span class="date-time">@post.CreatedAt?.ToString("yyyy-MM-dd")</span></td>
                                    <td>@post.ViewsCount</td>
                                    <td><span class="badge">@post.Upvotes 👍</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-message">No posts found</div>
                }
            </div>

            <!-- CATEGORIES TABLE -->
            <div class="table-section">
                <h2>📂 Categories (@Model.CategoryCount)</h2>
                @if (Model.Categories.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var category in Model.Categories.OrderBy(c => c.CategoryID))
                            {
                                <tr>
                                    <td><strong>@category.CategoryID</strong></td>
                                    <td>@category.CategoryName</td>
                                    <td>@category.Description</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-message">No categories found</div>
                }
            </div>

            <!-- TAGS TABLE -->
            <div class="table-section">
                <h2>🏷️ Tags (@Model.TagCount)</h2>
                @if (Model.Tags.Any())
                {
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tag in Model.Tags.OrderBy(t => t.TagID))
                            {
                                <tr>
                                    <td><strong>@tag.TagID</strong></td>
                                    <td><span class="badge">@tag.TagName</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-message">No tags found</div>
                }
            </div>
        </div>

        <div class="footer">
            <p>🔄 Refresh to see latest data | Database: Uni-Connect-DB | Last updated: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</p>
        </div>
    </div>
</body>
</html>
